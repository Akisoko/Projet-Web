<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inscription - Kezan</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="../assets/style.css">
</head>
<body class="landing-page">
<div class="auth-container signup-page">
    <div class="auth-form-card signup-card">
        <div class="signup-header">
            <div class="logo-container small">
                <img src="https://img.icons8.com/color/512/world-of-warcraft-horde.png" alt="Kezan Logo" class="landing-logo">
            </div>
            <div>
                <h2>Créer un compte</h2>
                <p class="auth-subtitle">Inscrivez vous pour commencer</p>
            </div>
        </div>

        <form class="auth-form signup-form" onsubmit="event.preventDefault(); window.location.href='accueil.html'">
            <div class="form-row">
                <div class="form-group">
                    <label>Civilité</label>
                    <div class="radio-group">
                        <label class="radio-label">
                            <input type="radio" name="civilite" value="mr" checked>
                            <span>Mr</span>
                        </label>
                        <label class="radio-label">
                            <input type="radio" name="civilite" value="mme">
                            <span>Mme</span>
                        </label>
                    </div>
                </div>

                <div class="form-group">
                    <label>Email</label>
                    <input type="email" required>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Nom</label>
                    <input type="text" required>
                </div>

                <div class="form-group">
                    <label>Téléphone</label>
                    <input type="tel" required>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Prénom</label>
                    <input type="text" required>
                </div>

                <div class="form-group">
                    <label>Mot de passe</label>
                    <input type="password" required>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Date de naissance</label>
                    <div class="date-group">
                        <select required>
                            <option value="">JJ</option>
                            <option value="01">01</option>
                            <option value="02">02</option>
                            <option value="03">03</option>
                        </select>
                        <select required>
                            <option value="">MM</option>
                            <option value="01">01</option>
                            <option value="02">02</option>
                            <option value="03">03</option>
                        </select>
                        <select required>
                            <option value="">AAAA</option>
                            <option value="2004">2004</option>
                            <option value="2003">2003</option>
                            <option value="2002">2002</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>Vérification</label>
                    <input type="password" placeholder="Confirmez le mot de passe" required>
                </div>
            </div>

            <button type="submit" class="btn-primary auth-submit">Sign up</button>
        </form>

        <p class="auth-footer">
            Déjà un compte ? <a href="connexion.twig">Se connecter</a>
        </p>
    </div>
</div>

</body>
</html>