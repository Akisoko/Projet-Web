{% extends "base.twig" %}

{% block title %}
    Détail offre - Kezan
{% endblock %}

{% block page_title %}
    Détail offre
{% endblock %}

{% block content %}

    <div class="detail-content">

        <div class="offer-detail-header">
            <div class="card-avatar">
                <i class="fa-solid fa-briefcase"></i>
            </div>
            <div class="offer-detail-info">
                <h2>{{ offre.titre ?? 'Titre de l\'offre' }}</h2>
                <p>{{ offre.entreprise ?? 'Entreprise' }}</p>
            </div>
            <button class="wishlist-heart">
                <i class="fa-{{ offre.wishlist ? 'solid' : 'regular' }} fa-heart"></i>
            </button>
        </div>

        <div class="offer-detail-body">

            <div class="detail-section">
                <h3>Description</h3>
                <p>{{ offre.description ?? 'Description de l\'offre' }}</p>
            </div>

            <div class="detail-section">
                <h3>Informations</h3>
                <p><i class="fa-solid fa-location-dot"></i> {{ offre.lieu ?? 'Lieu' }}</p>
                <p><i class="fa-solid fa-clock"></i> {{ offre.duree ?? 'Durée' }}</p>
                <p><i class="fa-solid fa-euro-sign"></i> {{ offre.remuneration ?? 'Rémunération' }}</p>
            </div>

        </div>

        <a href="/postuler?id={{ offre.id ?? '' }}" class="btn-primary">Postuler</a>

    </div>

{% endblock %}