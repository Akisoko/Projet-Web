{% extends "base_connexion.twig" %}

{% block title %}Kezan - Bienvenue{% endblock %}

{% block content %}

    <div class="landing-screen" id="welcomeScreen">
        <div class="landing-card">
            <div class="logo-container">
                <img src="https://img.icons8.com/color/512/world-of-warcraft-horde.png" alt="Kezan Logo" class="landing-logo">
            </div>
            <h1 class="brand-name">Kezan</h1>
            <button class="landing-btn" id="startBtn">Commencer</button>
        </div>
    </div>

    <div class="landing-screen hidden" id="loginScreen">
        <div class="landing-card">
            <div class="logo-container">
                <img src="https://img.icons8.com/color/512/world-of-warcraft-horde.png" alt="Kezan Logo" class="landing-logo">
            </div>
            <h2 class="login-title">Sign up/Log in</h2>

            <div class="login-form">
                <a href="accueil" class="btn-outline">Continuer en tant qu'invité</a>
                <a href="connexion" class="btn-primary">Se connecter</a>
            </div>
        </div>
    </div>

{% endblock %}