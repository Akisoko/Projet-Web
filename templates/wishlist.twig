{% extends "base.twig" %}
    {% block title %}Wishlist - Kezan{% endblock %}
    {% block page_title %}Wishlist{% endblock %}

    {% block content %}
        <div class="entity-content-wide">

            <div class="cards-grid">
                {% for offre in wishlist %}
                    <div class="company-card" style="position: relative;">

                        <a href="/detail_offre?id={{ offre.Id_Offre }}" style="text-decoration: none; color: inherit; display: block;">
                            <div class="card-header-row">
                                <div class="card-icon">
                                    <i class="fa-solid fa-briefcase"></i>
                                </div>
                                <div>
                                    <p class="card-title">{{ offre.Nom_Offre }}</p>
                                    <p class="card-subtitle">{{ offre.Nom_Entreprise }}</p>
                                    <span class="badge">{{ offre.Domaine_Offre }}</span>
                                </div>
                            </div>
                            <p class="card-description">{{ offre.Description_Offre }}</p>
                            <div class="card-footer-row">
                                <span><i class="fa-solid fa-euro-sign"></i>{{ offre.Remuneration }}</span>
                                <span><i class="fa-solid fa-calendar"></i>{{ offre.Date_Offre }}</span>
                            </div>
                        </a>

                        <a href="/wishlist_retirer?id={{ offre.Id_Offre }}"
                           class="wishlist-remove-btn"
                           onclick="return confirm('Retirer cette offre de la wishlist ?')">
                            <i class="fa-solid fa-heart"></i>
                        </a>

                    </div>
                {% else %}
                    <p class="empty-state">Votre wishlist est vide.</p>
                {% endfor %}
            </div>

        </div>
    {% endblock %}
