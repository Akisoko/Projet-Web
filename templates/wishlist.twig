{% extends "base.twig" %}

{% block title %}
    Wishlist - Kezan
{% endblock %}

{% block page_title %}
    Wishlist
{% endblock %}

{% block content %}

    <div class="wishlist-content">

        <div class="cards-grid">
            {% for offre in wishlist %}
                <a href="/detail_offre?id={{ offre.id }}" class="offer-card">

                    <div class="card-header">
                        <div class="card-avatar">
                            <i class="fa-solid fa-briefcase"></i>
                        </div>
                        <div class="card-lines">
                            <p class="offer-title">{{ offre.titre }}</p>
                            <p class="offer-company">{{ offre.entreprise }}</p>
                        </div>
                    </div>

                    <div class="card-body">
                        <p>{{ offre.description }}</p>
                        <p><i class="fa-solid fa-location-dot"></i> {{ offre.lieu }}</p>
                        <p><i class="fa-solid fa-clock"></i> {{ offre.duree }}</p>
                        <p><i class="fa-solid fa-euro-sign"></i> {{ offre.remuneration }}</p>
                    </div>

                    <button class="wishlist-heart">
                        <i class="fa-solid fa-heart"></i>
                    </button>

                </a>
            {% else %}
                <p>Votre wishlist est vide.</p>
            {% endfor %}
        </div>

    </div>

{% endblock %}