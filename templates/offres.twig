{% extends "base.twig" %}

{% block title %}
    Offres - Kezan
{% endblock %}

{% block page_title %}
    Offres
{% endblock %}

{% block content %}

    <div class="list-content">

        <div class="list-header">
            <input type="text" class="search-input" placeholder="Rechercher une offre...">
            <a href="/ajouter_offre" class="btn-primary">
                <i class="fa-solid fa-plus"></i>
                Ajouter
            </a>
        </div>

        <div class="cards-grid">
            {% for offre in offres %}
                <a href="/detail_offre?id={{ offre.id }}" class="offer-card">

                    <div class="card-header">
                        <div class="card-avatar">
                            <i class="fa-solid fa-briefcase"></i>
                        </div>
                        <div class="card-lines">
                            <p class="offer-title">{{ offre.titre }}</p>
                            <p class="offer-company">{{ offre.entreprise }}</p>
                        </div>
                    </div>

                    <div class="card-body">
                        <p>{{ offre.description }}</p>
                        <p><i class="fa-solid fa-location-dot"></i> {{ offre.lieu }}</p>
                        <p><i class="fa-solid fa-clock"></i> {{ offre.duree }}</p>
                        <p><i class="fa-solid fa-euro-sign"></i> {{ offre.remuneration }}</p>
                    </div>

                    <button class="wishlist-heart">
                        <i class="fa-{{ offre.wishlist ? 'solid' : 'regular' }} fa-heart"></i>
                    </button>

                </a>
            {% else %}
                <p>Aucune offre trouvée.</p>
            {% endfor %}
        </div>

    </div>

{% endblock %}