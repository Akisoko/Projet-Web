{% extends "base.twig" %}
{% block title %}Offres - Kezan{% endblock %}
{% block page_title %}Offres{% endblock %}

{% block content %}
    <div class="entity-content-wide">


            {% if auth_role == 1 or auth_role == 3 %}
                <a href="/ajouter_offre" class="btn-primary">
                    <i class="fa-solid fa-plus"></i>
                    Ajouter une offre
                </a>
            {% endif %}
        </div>

        <div class="cards-grid">
            {% for offre in offres %}
                <a href="/detail_offre?id={{ offre.Id_Offre }}" class="company-card">
                    <div class="card-header-row">
                        <div class="card-icon">
                            <i class="fa-solid fa-briefcase"></i>
                        </div>
                        <div>
                            <p class="card-title">{{ offre.Nom_Offre }}</p>
                            <span class="badge">{{ offre.Domaine_Offre }}</span>
                        </div>
                    </div>
                    <p class="card-description">{{ offre.Description_Offre }}</p>
                    <div class="card-footer-row">
                        <span><i class="fa-solid fa-euro-sign"></i>{{ offre.Remuneration }}</span>
                        <span><i class="fa-solid fa-calendar"></i>{{ offre.Date_Offre }}</span>
                        <span><i class="fa-solid fa-user-graduate"></i>{{ offre.Nombre_Etudiants }} étudiant(s)</span>
                    </div>
                </a>
            {% else %}
                <p class="empty-state">Aucune offre trouvée.</p>
            {% endfor %}
        </div>

        {% if totalPages > 1 %}
            <div class="pagination">
                {% if page > 1 %}
                    <a href="/offres?page={{ page - 1 }}" class="page-btn">
                        <i class="fa-solid fa-chevron-left"></i>
                    </a>
                {% endif %}
                {% for p in 1..totalPages %}
                    <a href="/offres?page={{ p }}" class="page-btn {{ p == page ? 'active' : '' }}">{{ p }}</a>
                {% endfor %}
                {% if page < totalPages %}
                    <a href="/offres?page={{ page + 1 }}" class="page-btn">
                        <i class="fa-solid fa-chevron-right"></i>
                    </a>
                {% endif %}
            </div>
        {% endif %}

    </div>
{% endblock %}
