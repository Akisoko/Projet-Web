<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Kezan{% endblock %}</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/assets/style.css">
</head>

<body>

<div class="container">

    <div class="overlay" id="overlay"></div>

    <aside class="sidebar" id="sidebar">

        <div class="logo">
            <img src="https://img.icons8.com/color/512/world-of-warcraft-horde.png" class="logo-img">
            <span class="logo-text">Kezan</span>
        </div>

        <nav class="nav-menu">
            <a href="/accueil" class="nav-item">
                <i class="fa-solid fa-house"></i>
                <span>Accueil</span>
            </a>

            <a href="/recherche" class="nav-item">
                <i class="fa-solid fa-magnifying-glass"></i>
                <span>Recherche</span>
            </a>

            <a href="/offres" class="nav-item">
                <i class="fa-solid fa-briefcase"></i>
                <span>Offres</span>
            </a>

            {% if auth_role == 2 %}
                <a href="/wishlist" class="nav-item">
                    <i class="fa-solid fa-heart"></i>
                    <span>Wishlist</span>
                </a>
            {% endif %}

            <a href="/entreprises" class="nav-item">
                <i class="fa-solid fa-building"></i>
                <span>Entreprises</span>
            </a>

            <a href="/statistiques" class="nav-item">
                <i class="fa-solid fa-chart-bar"></i>
                <span>Statistiques</span>
            </a>
        </nav>

        <div class="sidebar-bottom">

            <a href="/modifier_profil" class="nav-item">
                <i class="fa-solid fa-gear"></i>
                <span>Paramètres</span>
            </a>

            <a href="/mentions" class="nav-item">
                <i class="fa-solid fa-file-contract"></i>
                <span>Mentions légales</span>
            </a>

            <a href="/deconnexion" class="nav-item">
                <i class="fa-solid fa-right-from-bracket"></i>
                <span>Déconnexion</span>
            </a>

        </div>

    </aside>

    <main class="main-content">

        <header class="header">

            <div class="header-left">
                <button class="burger-menu" id="burgerMenu">
                    <i class="fa-solid fa-bars"></i>
                </button>

                <button class="back-button">
                    <i class="fa-solid fa-chevron-left"></i>
                </button>

                <h1>{% block page_title %}{% endblock %}</h1>

            </div>

            <div class="header-right">
                <a href="/profil" class="user-avatar">
                    <i class="fa-solid fa-user"></i>
                </a>
            </div>

        </header>

        <div class="page-content">

            {% block content %}
            {% endblock %}

        </div>

    </main>

</div>

<script src="/assets/script.js"></script>

</body>
</html>