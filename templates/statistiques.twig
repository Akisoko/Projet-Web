{% extends "base.twig" %}

{% block title %}
    Statistiques - Kezan
{% endblock %}

{% block page_title %}
    Statistiques
{% endblock %}

{% block content %}

    <div class="stats-content">

        <div class="stats-grid">

            <div class="stat-card">
                <div class="stat-icon">
                    <i class="fa-solid fa-briefcase"></i>
                </div>
                <div class="stat-info">
                    <h3>{{ stats.total_offres ?? 0 }}</h3>
                    <p>Offres disponibles</p>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon">
                    <i class="fa-solid fa-building"></i>
                </div>
                <div class="stat-info">
                    <h3>{{ stats.total_entreprises ?? 0 }}</h3>
                    <p>Entreprises</p>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon">
                    <i class="fa-solid fa-users"></i>
                </div>
                <div class="stat-info">
                    <h3>{{ stats.total_utilisateurs ?? 0 }}</h3>
                    <p>Utilisateurs</p>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon">
                    <i class="fa-solid fa-file-alt"></i>
                </div>
                <div class="stat-info">
                    <h3>{{ stats.total_candidatures ?? 0 }}</h3>
                    <p>Candidatures</p>
                </div>
            </div>

        </div>

        {% if stats.offres_par_ville is defined and stats.offres_par_ville is not empty %}
            <div class="detail-section">
                <h3>Offres par ville</h3>
                <div class="stats-list">
                    {% for ville, nombre in stats.offres_par_ville %}
                        <div class="stats-list-item">
                            <span>{{ ville }}</span>
                            <span class="badge">{{ nombre }}</span>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        {% if stats.offres_par_entreprise is defined and stats.offres_par_entreprise is not empty %}
            <div class="detail-section">
                <h3>Offres par entreprise</h3>
                <div class="stats-list">
                    {% for entreprise, nombre in stats.offres_par_entreprise %}
                        <div class="stats-list-item">
                            <span>{{ entreprise }}</span>
                            <span class="badge">{{ nombre }}</span>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

    </div>

{% endblock %}