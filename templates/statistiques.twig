{% extends "base.twig" %}
{% block title %}Statistiques - Kezan{% endblock %}
{% block page_title %}Statistiques{% endblock %}

{% block content %}
    <div class="stats-content">

        <div class="stats-overview">
            <div class="stat-card">
                <div class="stat-icon"><i class="fa-solid fa-briefcase"></i></div>
                <div class="stat-info">
                    <h3>{{ stats.total_offres }}</h3>
                    <p>Offres disponibles</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fa-solid fa-building"></i></div>
                <div class="stat-info">
                    <h3>{{ stats.total_entreprises }}</h3>
                    <p>Entreprises</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fa-solid fa-users"></i></div>
                <div class="stat-info">
                    <h3>{{ stats.total_utilisateurs }}</h3>
                    <p>Utilisateurs</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fa-solid fa-file-alt"></i></div>
                <div class="stat-info">
                    <h3>{{ stats.total_candidatures }}</h3>
                    <p>Candidatures</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fa-solid fa-chart-line"></i></div>
                <div class="stat-info">
                    <h3>{{ stats.moyenne_candidatures }}</h3>
                    <p>Candidatures / offre en moyenne</p>
                </div>
            </div>
        </div>

        <div class="charts-grid">

            <div class="detail-card chart-stat-card">
                <h3>Offres par domaine</h3>
                {% for row in stats.offres_par_domaine %}
                    <div class="progress-row">
                        <div class="progress-label-row">
                            <span>{{ row.Domaine_Offre }}</span>
                            <span>{{ row.nombre }}</span>
                        </div>
                        <div class="progress-track">
                            <div class="progress-fill" style="width: {{ (row.nombre / stats.total_offres * 100)|round }}%;"></div>
                        </div>
                    </div>
                {% else %}
                    <p style="color: #999;">Aucune donnée.</p>
                {% endfor %}
            </div>

            <div class="detail-card chart-stat-card">
                <h3>Offres par entreprise</h3>
                {% for row in stats.offres_par_entreprise %}
                    <div class="progress-row">
                        <div class="progress-label-row">
                            <span>{{ row.Nom_Entreprise }}</span>
                            <span>{{ row.nombre }}</span>
                        </div>
                        <div class="progress-track">
                            <div class="progress-fill" style="width: {{ (row.nombre / stats.total_offres * 100)|round }}%;"></div>
                        </div>
                    </div>
                {% else %}
                    <p style="color: #999;">Aucune donnée.</p>
                {% endfor %}
            </div>

            <div class="detail-card chart-stat-card">
                <h3>Top 5 offres les plus wishlistées</h3>
                {% for row in stats.top_wishlist %}
                    <div class="wishlist-stat-item">
                        <div class="wishlist-stat-item-info">
                            <p>{{ row.Nom_Offre }}</p>
                            <p>{{ row.Nom_Entreprise }}</p>
                        </div>
                        <span class="badge-dark">
                        <i class="fa-solid fa-heart"></i>{{ row.nombre }}
                    </span>
                    </div>
                {% else %}
                    <p style="color: #999;">Aucune donnée.</p>
                {% endfor %}
            </div>

        </div>

    </div>
{% endblock %}
