<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ajouter une offre - Kezan</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="../assets/style.css">
</head>
<body>
<div class="container">
    <div class="overlay" id="overlay"></div>

    <aside class="sidebar" id="sidebar">
        <div class="logo">
            <img src="https://img.icons8.com/color/512/world-of-warcraft-horde.png" alt="Kezan Logo" class="logo-img">
            <span class="logo-text">Kezan</span>
        </div>

        <nav class="nav-menu">
            <a href="accueil.twig" class="nav-item">
                <i class="fa-solid fa-house"></i>
                <span>Accueil</span>
            </a>
            <a href="recherche.twig" class="nav-item">
                <i class="fa-solid fa-magnifying-glass"></i>
                <span>Recherche de Profil</span>
            </a>
            <a href="offres.twig" class="nav-item active">
                <i class="fa-solid fa-briefcase"></i>
                <span>Offres</span>
            </a>
            <a href="entreprises.twig" class="nav-item">
                <i class="fa-solid fa-building"></i>
                <span>Entreprises</span>
            </a>
            <a href="statistiques.twig" class="nav-item">
                <i class="fa-solid fa-chart-bar"></i>
                <span>Statistiques</span>
            </a>
        </nav>

        <div class="sidebar-bottom">
            <a href="modifier_profil.twig" class="nav-item">
                <i class="fa-solid fa-gear"></i>
                <span>Paramètres</span>
            </a>
            <a href="mentions.twig" class="nav-item">
                <i class="fa-solid fa-file-contract"></i>
                <span>Terms & Conditions</span>
            </a>
            <a href="accueil.twig" class="nav-item">
                <i class="fa-solid fa-right-from-bracket"></i>
                <span>Deconnexion</span>
            </a>
        </div>
    </aside>

    <main class="main-content">
        <header class="header">
            <div class="header-left">
                <button class="burger-menu" id="burgerMenu">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <button class="back-button" onclick="window.location.href='liste_offre.html'">
                    <i class="fa-solid fa-chevron-left"></i>
                </button>
                <h1>Ajouter une offre</h1>
            </div>
            <div class="header-right">
                <button class="menu-dots">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <a href="profil.twig" class="user-avatar">
                    <i class="fa-solid fa-user"></i>
                </a>
            </div>
        </header>

        <div class="add-content">
            <form class="add-form">
                <div class="form-group">
                    <label>Nom responsable</label>
                    <input type="text" required>
                </div>

                <div class="form-group">
                    <label>Prénom responsable</label>
                    <input type="text" required>
                </div>

                <div class="form-group">
                    <label>E-mail responsable</label>
                    <input type="email" required>
                </div>

                <div class="form-group">
                    <label>Nom entreprise</label>
                    <input type="text" required>
                </div>

                <div class="form-group">
                    <label>Profil recherché</label>
                    <input type="text" required>
                </div>

                <div class="form-group">
                    <label>Domaine de l'offre</label>
                    <input type="text" required>
                </div>

                <div class="form-group">
                    <label>Description de l'offre</label>
                    <textarea rows="5" required></textarea>
                </div>

                <button type="submit" class="btn-primary add-submit">Ajouter</button>
            </form>
        </div>
    </main>
</div>

<script src="../assets/script.js"></script>
</body>
</html>