{% extends "base.twig" %}
{% block title %}Ajouter une offre - Kezan{% endblock %}
{% block page_title %}Ajouter une offre{% endblock %}
{% block content %}

    <div class="add-content">
        {% if erreur %}
            <p style="color:red; margin-bottom: 1rem;">{{ erreur }}</p>
        {% endif %}

        <form class="add-form" method="post" action="/ajouter_offre">

            <div class="form-group">
                <label>Nom de l'offre</label>
                <input type="text" name="nom" required>
            </div>

            <div class="form-group">
                <label>Domaine</label>
                <input type="text" name="domaine" required>
            </div>

            <div class="form-group">
                <label>Profil recherché</label>
                <input type="text" name="profil" required>
            </div>

            <div class="form-group">
                <label>Rémunération</label>
                <input type="text" name="remuneration" required>
            </div>

            <div class="form-group">
                <label>Date de l'offre</label>
                <input type="date" name="date_offre" required>
            </div>

            <div class="form-group">
                <label>Nombre d'étudiants recherchés</label>
                <input type="number" name="nb_etudiants" required>
            </div>

            <div class="form-group">
                <label>Entreprise</label>
                <select name="id_entreprise" required>
                    <option value="">-- Sélectionner une entreprise --</option>
                    {% for entreprise in entreprises %}
                        <option value="{{ entreprise.Id_Entreprise }}">{{ entreprise.Nom_Entreprise }}</option>
                    {% endfor %}
                </select>
            </div>

            <div class="form-group">
                <label>Description</label>
                <textarea name="description" rows="5" required></textarea>
            </div>

            <button type="submit" class="btn-primary add-submit">Ajouter</button>

        </form>
    </div>
{% endblock %}