{% extends "base.twig" %}

{% block title %}
    Ajouter une offre - Kezan
{% endblock %}

{% block page_title %}
    Ajouter une offre
{% endblock %}

{% block content %}

    <div class="add-content">
        <form class="add-form" method="post" action="/ajouter_offre">

            <div class="form-group">
                <label>Titre de l'offre</label>
                <input type="text" name="titre" required>
            </div>

            <div class="form-group">
                <label>Entreprise</label>
                <input type="text" name="entreprise" required>
            </div>

            <div class="form-group">
                <label>Lieu</label>
                <input type="text" name="lieu" required>
            </div>

            <div class="form-group">
                <label>Durée</label>
                <input type="text" name="duree" required>
            </div>

            <div class="form-group">
                <label>Rémunération</label>
                <input type="number" name="remuneration" required>
            </div>

            <div class="form-group">
                <label>Description</label>
                <textarea name="description" rows="5" required></textarea>
            </div>

            <button type="submit" class="btn-primary add-submit">Ajouter</button>

        </form>
    </div>

{% endblock %}