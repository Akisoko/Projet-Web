{% extends "base.twig" %}

{% block title %}
    Ajouter une entreprise - Kezan
{% endblock %}

{% block page_title %}
    Ajouter une entreprise
{% endblock %}

{% block content %}

    <div class="add-content">

        {% if erreur %}
            <p style="color:red;">{{ erreur }}</p>
        {% endif %}

        <form class="add-form" method="post" action="/ajouter_entreprise">

            <div class="form-group">
                <label>Nom entreprise</label>
                <input type="text" name="nom" required>
            </div>

            <div class="form-group">
                <label>Site web</label>
                <input type="text" name="site_web" required>
            </div>

            <div class="form-group">
                <label>Date de création</label>
                <input type="date" name="date_creation" required>
            </div>

            <div class="form-group">
                <label>Domaine</label>
                <input type="text" name="domaine" required>
            </div>

            <div class="form-group">
                <label>Nombre d'employés</label>
                <input type="number" name="nb_employes" required>
            </div>

            <div class="form-group">
                <label>Nombre de stagiaires</label>
                <input type="number" name="nb_stagiaires" required>
            </div>

            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" required>
            </div>

            <div class="form-group">
                <label>Téléphone</label>
                <input type="text" name="telephone" required>
            </div>

            <div class="form-group">
                <label>Description</label>
                <textarea name="description" rows="5" required></textarea>
            </div>

            <button type="submit" class="btn-primary add-submit">Ajouter</button>

        </form>
    </div>

{% endblock %}