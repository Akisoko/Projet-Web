{% extends "base.twig" %}

{% block title %}
    Modifier le profil - Kezan
{% endblock %}

{% block page_title %}
    Modifier le profil
{% endblock %}

{% block content %}

    <div class="add-content">
        <form class="add-form" method="post" action="/modifier_profil" enctype="multipart/form-data">

            <div class="form-group">
                <label>Prénom</label>
                <input type="text" name="prenom" value="{{ utilisateur.prenom ?? '' }}" required>
            </div>

            <div class="form-group">
                <label>Nom</label>
                <input type="text" name="nom" value="{{ utilisateur.nom ?? '' }}" required>
            </div>

            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" value="{{ utilisateur.email ?? '' }}" required>
            </div>

            <div class="form-group">
                <label>Téléphone</label>
                <input type="tel" name="telephone" value="{{ utilisateur.telephone ?? '' }}">
            </div>

            <div class="form-group">
                <label>Photo de profil</label>
                <div class="file-upload-group">
                    <input type="text" readonly placeholder="Aucun fichier sélectionné" id="photoFileName">
                    <label for="photoUpload" class="file-upload-btn">
                        <i class="fa-solid fa-upload"></i>
                    </label>
                    <input type="file" id="photoUpload" name="photo" accept="image/*" style="display: none;">
                </div>
            </div>

            <div class="form-group">
                <label>Nouveau mot de passe</label>
                <input type="password" name="mot_de_passe">
            </div>

            <div class="form-group">
                <label>Confirmer le mot de passe</label>
                <input type="password" name="mot_de_passe_confirmation">
            </div>

            <button type="submit" class="btn-primary add-submit">Enregistrer</button>

        </form>
    </div>

{% endblock %}