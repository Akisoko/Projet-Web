{% extends "base.twig" %}
{% block title %}Modifier le profil - Kezan{% endblock %}
{% block page_title %}Modifier le profil{% endblock %}

{% block content %}
    <div class="add-content">
        {% if erreur %}<p class="form-error">{{ erreur }}</p>{% endif %}

        <form class="add-form" method="post" action="/modifier_profil">

            <div class="form-group">
                <label>Prénom</label>
                <input type="text" name="prenom" value="{{ utilisateur.Prenom ?? '' }}" required>
            </div>
            <div class="form-group">
                <label>Nom</label>
                <input type="text" name="nom" value="{{ utilisateur.Nom_Utilisateur ?? '' }}" required>
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" value="{{ utilisateur.Email ?? '' }}" required>
            </div>
            <div class="form-group">
                <label>Téléphone</label>
                <input type="tel" name="telephone" value="{{ utilisateur.Telephone ?? '' }}">
            </div>
            <div class="form-group">
                <label>Nouveau mot de passe <span class="form-label-hint">(laisser vide pour ne pas changer)</span></label>
                <input type="password" name="mot_de_passe">
            </div>
            <div class="form-group">
                <label>Confirmer le mot de passe</label>
                <input type="password" name="mot_de_passe_confirmation">
            </div>

            <div class="form-btn-row">
                <a href="/profil" class="btn-secondary">Annuler</a>
                <button type="submit" class="btn-primary">Enregistrer</button>
            </div>

        </form>
    </div>
{% endblock %}
