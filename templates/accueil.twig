{% extends "base.twig" %}
{% block title %}Accueil - Kezan{% endblock %}
{% block page_title %}Accueil{% endblock %}

{% block content %}
    <div class="home-content">

        {# VUE ADMIN ET PILOTE #}
        {% if auth_role == 1 or auth_role == 3 %}

            <div class="stats-overview" style="margin-bottom: 2rem;">
                <div class="stat-card">
                    <div class="stat-icon"><i class="fa-solid fa-briefcase"></i></div>
                    <div class="stat-info">
                        <h3>{{ stats.total_offres }}</h3>
                        <p>Offres disponibles</p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon"><i class="fa-solid fa-building"></i></div>
                    <div class="stat-info">
                        <h3>{{ stats.total_entreprises }}</h3>
                        <p>Entreprises</p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon"><i class="fa-solid fa-file-alt"></i></div>
                    <div class="stat-info">
                        <h3>{{ stats.total_candidatures }}</h3>
                        <p>Candidatures</p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon"><i class="fa-solid fa-chart-line"></i></div>
                    <div class="stat-info">
                        <h3>{{ stats.moyenne_candidatures }}</h3>
                        <p>Candidatures / offre</p>
                    </div>
                </div>
            </div>

            {% if stats.top_wishlist is not empty %}
                <section style="margin-bottom: 2rem;">
                    <h2 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 1rem;">Top offres wishlistées</h2>
                    <div class="cards-grid">
                        {% for row in stats.top_wishlist %}
                            <div class="company-card" style="display: flex; justify-content: space-between; align-items: center;">
                                <div>
                                    <p style="font-weight: 600; font-size: 0.95rem;">{{ row.Nom_Offre }}</p>
                                    <p style="font-size: 0.8rem; color: #666;">{{ row.Nom_Entreprise }}</p>
                                </div>
                                <span style="background: #2c2c2c; color: #fff; font-size: 0.75rem; padding: 3px 10px; border-radius: 20px;">
                                <i class="fa-solid fa-heart" style="margin-right: 4px;"></i>{{ row.nombre }}
                            </span>
                            </div>
                        {% endfor %}
                    </div>
                </section>
            {% endif %}

        {% endif %}

        {# WISHLIST POUR LES ETUDIANTS #}
        {% if auth_role == 2 and wishlist is defined and wishlist is not empty %}
            <section style="margin-bottom: 2rem;">
                <h2 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 1rem;">Ma wishlist</h2>
                <div class="cards-grid">
                    {% for offre in wishlist %}
                        <a href="/detail_offre?id={{ offre.Id_Offre }}" class="company-card" style="text-decoration: none; color: inherit; display: block;">
                            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
                                <div style="width: 56px; height: 56px; background: #f0f0f0; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                    <i class="fa-solid fa-briefcase" style="color: #999; font-size: 1.25rem;"></i>
                                </div>
                                <div>
                                    <p style="font-weight: 600; font-size: 1rem; margin-bottom: 0.2rem;">{{ offre.Nom_Offre }}</p>
                                    <p style="font-size: 0.8rem; color: #666;">{{ offre.Nom_Entreprise }}</p>
                                </div>
                            </div>
                            <div style="display: flex; justify-content: space-between; font-size: 0.8rem; color: #999; border-top: 1px solid #f0f0f0; padding-top: 0.75rem;">
                                <span><i class="fa-solid fa-euro-sign" style="margin-right: 4px;"></i>{{ offre.Remuneration }}</span>
                                <span><i class="fa-solid fa-heart" style="margin-right: 4px; color: #e74c3c;"></i>En wishlist</span>
                            </div>
                        </a>
                    {% endfor %}
                </div>
            </section>
        {% endif %}

        {# DERNIERES OFFRES POUR TOUT LE MONDE #}
        <section>
            <h2 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 1rem;">
                {% if auth_role == 2 %}Dernières offres{% else %}Offres récentes{% endif %}
            </h2>
            <div class="cards-grid">
                {% for offre in dernieres_offres %}
                    <a href="/detail_offre?id={{ offre.Id_Offre }}" class="company-card" style="text-decoration: none; color: inherit; display: block;">
                        <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
                            <div style="width: 56px; height: 56px; background: #f0f0f0; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                <i class="fa-solid fa-briefcase" style="color: #999; font-size: 1.25rem;"></i>
                            </div>
                            <div>
                                <p style="font-weight: 600; font-size: 1rem; margin-bottom: 0.2rem;">{{ offre.Nom_Offre }}</p>
                                <p style="font-size: 0.8rem; color: #666; margin-bottom: 0.2rem;">{{ offre.Nom_Entreprise }}</p>
                                <span style="font-size: 0.8rem; background: #f0f0f0; color: #555; padding: 2px 10px; border-radius: 20px;">{{ offre.Domaine_Offre }}</span>
                            </div>
                        </div>
                        <div style="margin-bottom: 1rem;">
                            <p style="font-size: 0.875rem; color: #666; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                {{ offre.Description_Offre }}
                            </p>
                        </div>
                        <div style="display: flex; justify-content: space-between; font-size: 0.8rem; color: #999; border-top: 1px solid #f0f0f0; padding-top: 0.75rem;">
                            <span><i class="fa-solid fa-euro-sign" style="margin-right: 4px;"></i>{{ offre.Remuneration }}</span>
                            <span><i class="fa-solid fa-calendar" style="margin-right: 4px;"></i>{{ offre.Date_Offre }}</span>
                        </div>
                    </a>
                {% else %}
                    <p style="color: #999; grid-column: 1/-1; text-align: center; padding: 3rem;">Aucune offre disponible.</p>
                {% endfor %}
            </div>
        </section>

    </div>
{% endblock %}