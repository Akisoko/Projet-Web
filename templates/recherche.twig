{% extends "base.twig" %}
{% block title %}Recherche - Kezan{% endblock %}
{% block page_title %}Recherche{% endblock %}

{% block content %}
    <div class="search-content">

        <form class="search-form" method="get" action="/recherche">
            <div class="search-bar">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" name="q" placeholder="Rechercher..." value="{{ query ?? '' }}">
                <button type="submit" class="btn-primary">Rechercher</button>
            </div>
            <div class="search-filters">
                <select name="type">
                    <option value="">Tout</option>
                    <option value="offre" {{ query_type == 'offre' ? 'selected' : '' }}>Offres</option>
                    <option value="entreprise" {{ query_type == 'entreprise' ? 'selected' : '' }}>Entreprises</option>
                    {% if auth_role == 1 or auth_role == 3 %}
                        <option value="profil" {{ query_type == 'profil' ? 'selected' : '' }}>Profils</option>
                    {% endif %}
                </select>
            </div>
        </form>

        <div class="search-results">
            {% if resultats is defined and resultats is not empty %}
                {% for resultat in resultats %}
                    <a href="{{ resultat.url }}" class="entity-item">
                        <div class="result-icon">
                            {% if resultat.type == 'offre' %}
                                <i class="fa-solid fa-briefcase"></i>
                            {% elseif resultat.type == 'entreprise' %}
                                <i class="fa-solid fa-building"></i>
                            {% else %}
                                <i class="fa-solid fa-user"></i>
                            {% endif %}
                        </div>
                        <div class="entity-item-info">
                            <h3>{{ resultat.titre }}</h3>
                            <p class="result-description">{{ resultat.description }}</p>
                        </div>
                        <span class="result-type-badge">{{ resultat.type }}</span>
                    </a>
                {% endfor %}
            {% elseif query is defined and query is not empty %}
                <p class="empty-state">Aucun résultat pour "{{ query }}".</p>
            {% endif %}
        </div>

    </div>
{% endblock %}
