{% extends "base.twig" %}

{% block title %}
    Profil - Kezan
{% endblock %}

{% block page_title %}
    Profil
{% endblock %}

{% block content %}

    <div class="profile-content">

        <div class="profile-header">
            <div class="profile-avatar">
                <i class="fa-solid fa-user"></i>
            </div>
            <div class="profile-info">
                <h2>{{ utilisateur.prenom ?? '' }} {{ utilisateur.nom ?? '' }}</h2>
                <p>{{ utilisateur.email ?? '' }}</p>
                <p>{{ utilisateur.role ?? '' }}</p>
            </div>
            <a href="/modifier_profil" class="btn-primary">
                <i class="fa-solid fa-pen"></i>
                Modifier
            </a>
        </div>

        <div class="profile-body">

            <div class="detail-section">
                <h3>Informations personnelles</h3>
                <p><i class="fa-solid fa-phone"></i> {{ utilisateur.telephone ?? 'Non renseigné' }}</p>
                <p><i class="fa-solid fa-envelope"></i> {{ utilisateur.email ?? 'Non renseigné' }}</p>
            </div>

            <div class="detail-section">
                <h3>Mes candidatures</h3>
                {% for candidature in candidatures %}
                    <a href="/detail_offre?id={{ candidature.offre_id }}" class="candidature-item">
                        <p>{{ candidature.offre_titre }}</p>
                        <p>{{ candidature.entreprise }}</p>
                        <span class="status {{ candidature.statut }}">{{ candidature.statut }}</span>
                    </a>
                {% else %}
                    <p>Aucune candidature pour le moment.</p>
                {% endfor %}
            </div>

        </div>

    </div>

{% endblock %}