{% extends "base.twig" %}

{% block title %}
    Modifier une offre - Kezan
{% endblock %}

{% block page_title %}
    Modifier une offre
{% endblock %}

{% block content %}

    <div class="add-content">
        <form class="add-form" method="post" action="/modifier_offre">

            <input type="hidden" name="id" value="{{ offre.id ?? '' }}">

            <div class="form-group">
                <label>Titre de l'offre</label>
                <input type="text" name="titre" value="{{ offre.titre ?? '' }}" required>
            </div>

            <div class="form-group">
                <label>Entreprise</label>
                <input type="text" name="entreprise" value="{{ offre.entreprise ?? '' }}" required>
            </div>

            <div class="form-group">
                <label>Lieu</label>
                <input type="text" name="lieu" value="{{ offre.lieu ?? '' }}" required>
            </div>

            <div class="form-group">
                <label>Durée</label>
                <input type="text" name="duree" value="{{ offre.duree ?? '' }}" required>
            </div>

            <div class="form-group">
                <label>Rémunération</label>
                <input type="number" name="remuneration" value="{{ offre.remuneration ?? '' }}" required>
            </div>

            <div class="form-group">
                <label>Description</label>
                <textarea name="description" rows="5" required>{{ offre.description ?? '' }}</textarea>
            </div>

            <button type="submit" class="btn-primary add-submit">Modifier</button>

        </form>
    </div>

{% endblock %}