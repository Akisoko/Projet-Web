{% extends "base.twig" %}
{% block title %}Postuler - Kezan{% endblock %}
{% block page_title %}Postuler{% endblock %}

{% block content %}
    <div class="add-content">
        {% if erreur %}<p class="form-error">{{ erreur }}</p>{% endif %}

        <form class="add-form" method="post" action="/postuler?id={{ offre.Id_Offre }}" enctype="multipart/form-data">

            <input type="hidden" name="offre_id" value="{{ offre.Id_Offre ?? '' }}">

            <div class="form-group">
                <label>Offre</label>
                <input type="text" value="{{ offre.Nom_Offre ?? '' }}" readonly>
            </div>
            <div class="form-group">
                <label>Entreprise</label>
                <input type="text" value="{{ offre.Nom_Entreprise ?? '' }}" readonly>
            </div>
            <div class="form-group">
                <label>CV <span class="form-label-hint">(PDF uniquement)</span></label>
                <div class="file-upload-group">
                    <input type="text" readonly placeholder="Aucun fichier sélectionné" id="cvFileName">
                    <label for="cvUpload" class="file-upload-btn">
                        <i class="fa-solid fa-upload"></i>
                    </label>
                    <input type="file" id="cvUpload" name="cv" accept=".pdf" style="display: none;">
                </div>
            </div>
            <div class="form-group">
                <label>Lettre de motivation <span class="form-label-hint">(PDF uniquement, facultative)</span></label>
                <div class="file-upload-group">
                    <input type="text" readonly placeholder="Aucun fichier sélectionné" id="lmFileName">
                    <label for="lmUpload" class="file-upload-btn">
                        <i class="fa-solid fa-upload"></i>
                    </label>
                    <input type="file" id="lmUpload" name="lettre_motivation" accept=".pdf" style="display: none;">
                </div>
            </div>

            <div class="form-btn-row">
                <a href="/detail_offre?id={{ offre.Id_Offre }}" class="btn-secondary">Annuler</a>
                <button type="submit" class="btn-primary">Envoyer ma candidature</button>
            </div>

        </form>
    </div>
{% endblock %}
