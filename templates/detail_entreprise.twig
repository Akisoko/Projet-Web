{% extends "base.twig" %}

{% block title %}
    Détail entreprise - Kezan
{% endblock %}

{% block page_title %}
    Détail entreprise
{% endblock %}

{% block content %}

    <div class="detail-content">

        <div class="company-detail-header">
            <div class="company-logo-large">
                Logo<br>Entreprise
            </div>
            <div class="company-detail-info">
                <h2>{{ entreprise.nom ?? 'Nom entreprise' }}</h2>
                <p>{{ entreprise.secteur ?? 'Secteur' }}</p>
            </div>
        </div>

        <div class="company-detail-body">

            <div class="detail-section">
                <h3>À propos</h3>
                <p>{{ entreprise.description ?? 'Description de l\'entreprise' }}</p>
            </div>

            <div class="detail-section">
                <h3>Informations</h3>
                <p><i class="fa-solid fa-location-dot"></i> {{ entreprise.adresse ?? 'Adresse' }}</p>
                <p><i class="fa-solid fa-phone"></i> {{ entreprise.telephone ?? 'Téléphone' }}</p>
                <p><i class="fa-solid fa-envelope"></i> {{ entreprise.email ?? 'Email' }}</p>
            </div>

        </div>

    </div>

{% endblock %}