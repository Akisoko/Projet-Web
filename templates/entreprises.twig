{% extends "base.twig" %}

{% block title %}
    Entreprises - Kezan
{% endblock %}

{% block page_title %}
    Entreprises
{% endblock %}

{% block content %}

    <div class="list-content">

        <div class="list-header">
            <input type="text" class="search-input" placeholder="Rechercher une entreprise...">
            <a href="/ajouter_entreprise" class="btn-primary">
                <i class="fa-solid fa-plus"></i>
                Ajouter
            </a>
        </div>

        <div class="cards-grid">
            {% for entreprise in entreprises %}
                <a href="/detail_entreprise?id={{ entreprise.id }}" class="company-card">

                    <div class="company-header">
                        <div class="company-logo">
                            Logo<br>Entreprise
                        </div>
                        <div class="company-info">
                            <p class="company-name">{{ entreprise.nom }}</p>
                            <p class="company-sector">{{ entreprise.secteur }}</p>
                        </div>
                    </div>

                    <div class="company-body">
                        <p>{{ entreprise.description }}</p>
                    </div>

                    <div class="company-footer">
                        <span class="location">
                            <i class="fa-solid fa-location-dot"></i>
                            {{ entreprise.adresse }}
                        </span>
                    </div>

                </a>
            {% else %}
                <p>Aucune entreprise trouvée.</p>
            {% endfor %}
        </div>

    </div>

{% endblock %}