{% extends "base.twig" %}
{% block title %}Entreprises - Kezan{% endblock %}
{% block page_title %}Entreprises{% endblock %}

{% block content %}
    <div class="entity-content-wide">

        <div class="entity-search-bar">
            <div class="search-input-wrapper">
                <i class="fa-solid fa-magnifying-glass search-icon"></i>
                <input type="text" class="search-input" placeholder="Rechercher une entreprise...">
            </div>
            {% if auth_role == 1 or auth_role == 3 %}
                <a href="/ajouter_entreprise" class="btn-primary">
                    <i class="fa-solid fa-plus"></i>
                    Ajouter une entreprise
                </a>
            {% endif %}
        </div>

        <div class="cards-grid">
            {% for entreprise in entreprises %}
                <a href="/detail_entreprise?id={{ entreprise.Id_Entreprise }}" class="company-card">
                    <div class="card-header-row">
                        <div class="card-icon">
                            <i class="fa-solid fa-building"></i>
                        </div>
                        <div>
                            <p class="card-title">{{ entreprise.Nom_Entreprise }}</p>
                            <span class="badge">{{ entreprise.Domaine_Entreprise }}</span>
                        </div>
                    </div>
                    <p class="card-description">{{ entreprise.Description_Entreprise }}</p>
                    <div class="card-footer-row">
                        <span><i class="fa-solid fa-users"></i>{{ entreprise.Nombre_Employes }} employés</span>
                        <span><i class="fa-solid fa-user-graduate"></i>{{ entreprise.Nombre_Stagiaires }} stagiaires</span>
                    </div>
                </a>
            {% else %}
                <p class="empty-state">Aucune entreprise trouvée.</p>
            {% endfor %}
        </div>

        {% if totalPages > 1 %}
            <div class="pagination">
                {% if page > 1 %}
                    <a href="/entreprises?page={{ page - 1 }}" class="page-btn">
                        <i class="fa-solid fa-chevron-left"></i>
                    </a>
                {% endif %}
                {% for p in 1..totalPages %}
                    <a href="/entreprises?page={{ p }}" class="page-btn {{ p == page ? 'active' : '' }}">{{ p }}</a>
                {% endfor %}
                {% if page < totalPages %}
                    <a href="/entreprises?page={{ page + 1 }}" class="page-btn">
                        <i class="fa-solid fa-chevron-right"></i>
                    </a>
                {% endif %}
            </div>
        {% endif %}

    </div>
{% endblock %}
