{% extends "base.twig" %}

{% block title %}
    Entreprises - Kezan
{% endblock %}

{% block page_title %}
    Entreprises
{% endblock %}

{% block content %}

    <div class="entity-content" style="max-width: 1200px;">

        <div class="entity-search" style="justify-content: space-between; align-items: center; margin-bottom: 2rem;">
            <div class="search-input-wrapper" style="flex: 1; max-width: 400px; position: relative;">
                <i class="fa-solid fa-magnifying-glass search-icon"></i>
                <input type="text" class="search-input" placeholder="Rechercher une entreprise...">
            </div>
            {% if auth_role == 1 or auth_role == 3 %}
                <a href="/ajouter_entreprise" class="btn-primary" style="display: flex; align-items: center; gap: 0.5rem; text-decoration: none; white-space: nowrap;">
                    <i class="fa-solid fa-plus"></i>
                    Ajouter une entreprise
                </a>
            {% endif %}
        </div>

        <div class="cards-grid">
            {% for entreprise in entreprises %}
                <a href="/detail_entreprise?id={{ entreprise.Id_Entreprise }}" class="company-card" style="text-decoration: none; color: inherit; display: block;">

                    <div class="company-header" style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
                        <div class="company-logo" style="background: #f0f0f0; border-radius: 8px; width: 56px; height: 56px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                            <i class="fa-solid fa-building" style="color: #999; font-size: 1.25rem;"></i>
                        </div>
                        <div>
                            <p class="company-name" style="font-weight: 600; font-size: 1rem; margin-bottom: 0.2rem;">{{ entreprise.Nom_Entreprise }}</p>
                            <span style="font-size: 0.8rem; background: #f0f0f0; color: #555; padding: 2px 10px; border-radius: 20px;">{{ entreprise.Domaine_Entreprise }}</span>
                        </div>
                    </div>

                    <div class="company-body" style="margin-bottom: 1rem;">
                        <p style="font-size: 0.875rem; color: #666; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                            {{ entreprise.Description_Entreprise }}
                        </p>
                    </div>

                    <div style="display: flex; justify-content: space-between; align-items: center; font-size: 0.8rem; color: #999; border-top: 1px solid #f0f0f0; padding-top: 0.75rem; margin-top: auto;">
                        <span><i class="fa-solid fa-users" style="margin-right: 4px;"></i>{{ entreprise.Nombre_Employes }} employés</span>
                        <span><i class="fa-solid fa-user-graduate" style="margin-right: 4px;"></i>{{ entreprise.Nombre_Stagiaires }} stagiaires</span>
                    </div>

                </a>
            {% else %}
                <p style="color: #999; grid-column: 1/-1; text-align: center; padding: 3rem;">Aucune entreprise trouvée.</p>
            {% endfor %}
        </div>

    </div>

{% endblock %}