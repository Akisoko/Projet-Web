{% extends "base.twig" %}

{# Titre affiché dans l'onglet du navigateur #}
{% block title %}Ajouter une offre - Kezan{% endblock %}

{# Titre principal de la page #}
{% block page_title %}Ajouter une offre{% endblock %}

{% block content %}
    <div class="add-content">

        {# Affiche un message d'erreur si le contrôleur en transmet un #}
        {% if erreur %}
            <p class="error-message" style="color:red; margin-bottom: 1rem;">{{ erreur }}</p>
        {% endif %}

        {# Formulaire d'ajout d'une nouvelle offre #}
        <form class="add-form" method="post" action="/ajouter_offre">

            {# Nom de l'offre proposée #}
            <div class="form-group">
                <label for="nom">Nom de l'offre</label>
                <input type="text" id="nom" name="nom" required>
            </div>

            {# Domaine d'activité de l'offre #}
            <div class="form-group">
                <label for="domaine">Domaine</label>
                <input type="text" id="domaine" name="domaine" required>
            </div>

            {# Profil recherché pour cette offre #}
            <div class="form-group">
                <label for="profil">Profil recherché</label>
                <input type="text" id="profil" name="profil" required>
            </div>

            {# Rémunération prévue pour l'offre #}
            <div class="form-group">
                <label for="remuneration">Rémunération</label>
                <input type="text" id="remuneration" name="remuneration" required>
            </div>

            {# Date de publication ou de disponibilité de l'offre #}
            <div class="form-group">
                <label for="date_offre">Date de l'offre</label>
                <input type="date" id="date_offre" name="date_offre" required>
            </div>

            {# Nombre d'étudiants recherchés pour cette offre #}
            <div class="form-group">
                <label for="nb_etudiants">Nombre d'étudiants recherchés</label>
                <input type="number" id="nb_etudiants" name="nb_etudiants" min="1" required>
            </div>

            {# Sélection de l'entreprise à laquelle rattacher l'offre #}
            <div class="form-group">
                <label for="id_entreprise">Entreprise</label>
                <select id="id_entreprise" name="id_entreprise" required>
                    <option value="">-- Sélectionner une entreprise --</option>

                    {# Génère les options à partir de la liste des entreprises envoyée par le contrôleur #}
                    {% for entreprise in entreprises %}
                        <option value="{{ entreprise.Id_Entreprise }}">
                            {{ entreprise.Nom_Entreprise }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            {# Description détaillée de l'offre #}
            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" rows="5" required></textarea>
            </div>

            {# Bouton d'envoi du formulaire #}
            <button type="submit" class="btn-primary add-submit">
                Ajouter
            </button>

        </form>
    </div>
{% endblock %}