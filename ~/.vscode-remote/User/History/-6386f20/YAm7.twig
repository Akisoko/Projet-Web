{% extends "base.twig" %}

{# Titre de l'onglet du navigateur #}
{% block title %}Détail entreprise - Kezan{% endblock %}

{# Titre principal affiché dans la page #}
{% block page_title %}Détail entreprise{% endblock %}

{% block content %}
    <div class="detail-content">
        <div class="detail-card">

            {# En-tête principal de la fiche entreprise #}
            <div class="detail-card-header">
                <div class="company-logo large">
                    <i class="fa-solid fa-building" style="font-size: 2rem; color: #999;" aria-hidden="true"></i>
                </div>

                <div class="detail-title">
                    <h2>{{ entreprise.Nom_Entreprise }}</h2>
                    <p><span class="badge">{{ entreprise.Domaine_Entreprise }}</span></p>
                </div>
            </div>

            {# Présentation générale de l'entreprise #}
            <div class="detail-section">
                <h3>À propos</h3>
                <p class="detail-text">{{ entreprise.Description_Entreprise }}</p>
            </div>

            {# Bloc des informations détaillées de l'entreprise #}
            <div class="detail-section">
                <h3>Informations</h3>

                <div class="info-list">

                    {# Site web de l'entreprise #}
                    <div class="info-row">
                        <div class="info-icon">
                            <i class="fa-solid fa-globe" aria-hidden="true"></i>
                        </div>
                        <div>
                            <p class="info-label">Site web</p>
                            <p class="info-value">
                                {{ entreprise.Site_Web }}
                            </p>
                        </div>
                    </div>

                    {# Numéro de téléphone de contact #}
                    <div class="info-row">
                        <div class="info-icon">
                            <i class="fa-solid fa-phone" aria-hidden="true"></i>
                        </div>
                        <div>
                            <p class="info-label">Téléphone</p>
                            <p class="info-value">{{ entreprise.Telephone }}</p>
                        </div>
                    </div>

                    {# Adresse email de contact #}
                    <div class="info-row">
                        <div class="info-icon">
                            <i class="fa-solid fa-envelope" aria-hidden="true"></i>
                        </div>
                        <div>
                            <p class="info-label">Email</p>
                            <p class="info-value">{{ entreprise.Mail }}</p>
                        </div>
                    </div>

                    {# Informations chiffrées sur l'effectif #}
                    <div class="info-row-grid">
                        <div class="info-row">
                            <div class="info-icon">
                                <i class="fa-solid fa-users" aria-hidden="true"></i>
                            </div>
                            <div>
                                <p class="info-label">Employés</p>
                                <p class="info-value-bold">{{ entreprise.Nombre_Employes }}</p>
                            </div>
                        </div>

                        <div class="info-row">
                            <div class="info-icon">
                                <i class="fa-solid fa-user-graduate" aria-hidden="true"></i>
                            </div>
                            <div>
                                <p class="info-label">Stagiaires</p>
                                <p class="info-value-bold">{{ entreprise.Nombre_Stagiaires }}</p>
                            </div>
                        </div>
                    </div>

                    {# Date de création de l'entreprise #}
                    <div class="info-row">
                        <div class="info-icon">
                            <i class="fa-solid fa-calendar" aria-hidden="true"></i>
                        </div>
                        <div>
                            <p class="info-label">Fondée le</p>
                            <p class="info-value">{{ entreprise.Date_Creation }}</p>
                        </div>
                    </div>

                </div>
            </div>

            {# Actions disponibles uniquement pour les admins et pilotes #}
            <div class="detail-actions">
                {% if auth_role == 1 or auth_role == 3 %}
                    <a href="/noter_entreprise?id={{ entreprise.Id_Entreprise }}"
                       class="detail-action-btn note"
                       style="background-color: #f39c12; color: #fff;">
                        <i class="fa-solid fa-star" aria-hidden="true"></i>
                        Noter
                    </a>

                    <a href="/modifier_entreprise?id={{ entreprise.Id_Entreprise }}" class="detail-action-btn edit">
                        <i class="fa-solid fa-pen" aria-hidden="true"></i>
                        Modifier
                    </a>

                    <a href="/supprimer_entreprise?id={{ entreprise.Id_Entreprise }}"
                       class="detail-action-btn delete"
                       onclick="return confirm('Supprimer cette entreprise ?')">
                        <i class="fa-solid fa-trash" aria-hidden="true"></i>
                        Supprimer
                    </a>
                {% endif %}
            </div>

        </div>
    </div>
{% endblock %}