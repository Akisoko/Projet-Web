{% extends "base.twig" %}

{# Titre de l'onglet navigateur #}
{% block title %}Modifier une offre - Kezan{% endblock %}

{# Titre principal affiché dans la page #}
{% block page_title %}Modifier une offre{% endblock %}

{% block content %}
    <div class="add-content">

        {# Message d'erreur affiché si le contrôleur renvoie une erreur #}
        {% if erreur %}
            <p class="form-error">{{ erreur }}</p>
        {% endif %}

        {# Formulaire de modification d'une offre existante #}
        <form class="add-form" method="post" action="/modifier_offre?id={{ offre.Id_Offre }}">

            {# Nom de l'offre #}
            <div class="form-group">
                <label for="nom">Nom de l'offre</label>
                <input type="text" id="nom" name="nom" value="{{ offre.Nom_Offre }}" required>
            </div>

            {# Domaine de l'offre #}
            <div class="form-group">
                <label for="domaine">Domaine</label>
                <input type="text" id="domaine" name="domaine" value="{{ offre.Domaine_Offre }}" required>
            </div>

            {# Profil recherché pour cette offre #}
            <div class="form-group">
                <label for="profil">Profil recherché</label>
                <input type="text" id="profil" name="profil" value="{{ offre.Profil_Recherche }}" required>
            </div>

            {# Informations de rémunération #}
            <div class="form-group">
                <label for="remuneration">Rémunération</label>
                <input type="text" id="remuneration" name="remuneration" value="{{ offre.Remuneration }}" required>
            </div>

            {# Date associée à l'offre #}
            <div class="form-group">
                <label for="date_offre">Date de l'offre</label>
                <input type="date" id="date_offre" name="date_offre" value="{{ offre.Date_Offre }}" required>
            </div>

            {# Nombre d'étudiants recherchés #}
            <div class="form-group">
                <label for="nb_etudiants">Nombre d'étudiants recherchés</label>
                <input type="number" id="nb_etudiants" name="nb_etudiants" value="{{ offre.Nombre_Etudiants }}" required>
            </div>

            {# Entreprise associée à l'offre #}
            <div class="form-group">
                <label for="id_entreprise">Entreprise</label>
                <select id="id_entreprise" name="id_entreprise" required>
                    <option value="">-- Sélectionner une entreprise --</option>

                    {% for entreprise in entreprises %}
                        <option value="{{ entreprise.Id_Entreprise }}"
                            {{ offre.Id_Entreprise == entreprise.Id_Entreprise ? 'selected' : '' }}>
                            {{ entreprise.Nom_Entreprise }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            {# Description complète de l'offre #}
            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" rows="5" required>{{ offre.Description_Offre }}</textarea>
            </div>

            {# Boutons d'action : annulation ou enregistrement #}
            <div class="form-btn-row">
                <a href="/detail_offre?id={{ offre.Id_Offre }}" class="btn-secondary">
                    Annuler
                </a>

                <button type="submit" class="btn-primary">
                    Enregistrer les modifications
                </button>
            </div>

        </form>
    </div>
{% endblock %}