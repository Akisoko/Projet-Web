{% extends "base.twig" %}

{# Titre affiché dans l'onglet du navigateur #}
{% block title %}Modifier un utilisateur - Kezan{% endblock %}

{# Titre principal affiché dans la page #}
{% block page_title %}Modifier un utilisateur{% endblock %}

{% block content %}
    <div class="add-content">

        {# Message d'erreur affiché si une erreur est renvoyée par le contrôleur #}
        {% if erreur %}
            <p class="form-error">{{ erreur }}</p>
        {% endif %}

        {# Formulaire de modification d'un utilisateur existant #}
        <form class="add-form" method="post" action="/modifier_utilisateur?id={{ utilisateur.Id_Utilisateur }}">

            {# Champ prénom, prérempli si disponible #}
            <div class="form-group">
                <label for="prenom">Prénom</label>
                <input type="text" id="prenom" name="prenom" value="{{ utilisateur.Prenom ?? '' }}" required>
            </div>

            {# Champ nom, prérempli si disponible #}
            <div class="form-group">
                <label for="nom">Nom</label>
                <input type="text" id="nom" name="nom" value="{{ utilisateur.Nom_Utilisateur ?? '' }}" required>
            </div>

            {# Champ email, prérempli si disponible #}
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" value="{{ utilisateur.Email ?? '' }}" required>
            </div>

            {# Champ téléphone, facultatif #}
            <div class="form-group">
                <label for="telephone">Téléphone</label>
                <input type="tel" id="telephone" name="telephone" value="{{ utilisateur.Telephone ?? '' }}">
            </div>

            {# Sélection du rôle, visible uniquement pour un administrateur #}
            {% if auth_role == 1 %}
                <div class="form-group">
                    <label for="id_role">Rôle</label>
                    <select id="id_role" name="id_role">
                        <option value="1" {{ utilisateur.Id_Role == 1 ? 'selected' : '' }}>Admin</option>
                        <option value="2" {{ utilisateur.Id_Role == 2 ? 'selected' : '' }}>Étudiant</option>
                        <option value="3" {{ utilisateur.Id_Role == 3 ? 'selected' : '' }}>Pilote</option>
                    </select>
                </div>
            {% endif %}

            {# Boutons d'action du formulaire #}
            <div class="form-btn-row">
                <a href="/detail_utilisateur?id={{ utilisateur.Id_Utilisateur }}" class="btn-secondary">
                    Annuler
                </a>

                <button type="submit" class="btn-primary">
                    Enregistrer
                </button>
            </div>

        </form>
    </div>
{% endblock %}