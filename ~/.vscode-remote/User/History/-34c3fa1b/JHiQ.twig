{% extends "base.twig" %}

{# Titre affiché dans l'onglet du navigateur #}
{% block title %}Modifier le profil - Kezan{% endblock %}

{# Titre principal affiché dans la page #}
{% block page_title %}Modifier le profil{% endblock %}

{% block content %}
    <div class="add-content">

        {# Message d'erreur affiché si une erreur est renvoyée par le contrôleur #}
        {% if erreur %}
            <p class="form-error">{{ erreur }}</p>
        {% endif %}

        {# Formulaire de modification du profil utilisateur #}
        <form class="add-form" method="post" action="/modifier_profil">

            {# Champ prénom, prérempli si la donnée existe #}
            <div class="form-group">
                <label for="prenom">Prénom</label>
                <input type="text" id="prenom" name="prenom" value="{{ utilisateur.Prenom ?? '' }}" required>
            </div>

            {# Champ nom, prérempli si la donnée existe #}
            <div class="form-group">
                <label for="nom">Nom</label>
                <input type="text" id="nom" name="nom" value="{{ utilisateur.Nom_Utilisateur ?? '' }}" required>
            </div>

            {# Champ email de l'utilisateur #}
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" value="{{ utilisateur.Email ?? '' }}" required>
            </div>

            {# Champ téléphone, facultatif #}
            <div class="form-group">
                <label for="telephone">Téléphone</label>
                <input type="tel" id="telephone" name="telephone" value="{{ utilisateur.Telephone ?? '' }}">
            </div>

            {# Nouveau mot de passe, laissé vide si l'utilisateur ne veut pas le modifier #}
            <div class="form-group">
                <label for="mot_de_passe">
                    Nouveau mot de passe
                    <span class="form-label-hint">(laisser vide pour ne pas changer)</span>
                </label>
                <input type="password"
                       id="mot_de_passe"
                       name="mot_de_passe"
                       autocomplete="new-password">
            </div>

            {# Confirmation du nouveau mot de passe #}
            <div class="form-group">
                <label for="mot_de_passe_confirmation">Confirmer le mot de passe</label>
                <input type="password"
                       id="mot_de_passe_confirmation"
                       name="mot_de_passe_confirmation"
                       autocomplete="new-password">
            </div>

            {# Boutons d'action du formulaire #}
            <div class="form-btn-row">
                <a href="/profil" class="btn-secondary">Annuler</a>
                <button type="submit" class="btn-primary">Enregistrer</button>
            </div>

        </form>
    </div>
{% endblock %}