{% extends "base.twig" %}

{# Titre affiché dans l'onglet du navigateur #}
{% block title %}Postuler - Kezan{% endblock %}

{# Titre principal affiché dans la page #}
{% block page_title %}Postuler{% endblock %}

{% block content %}
    <div class="add-content">

        {# Message d'erreur affiché si le contrôleur renvoie un problème #}
        {% if erreur %}
            <p class="form-error">{{ erreur }}</p>
        {% endif %}

        {# Formulaire de candidature avec envoi de fichiers #}
        <form class="add-form"
              method="post"
              action="/postuler?id={{ offre.Id_Offre }}"
              enctype="multipart/form-data">

            {# Identifiant de l'offre transmis au serveur #}
            <input type="hidden" name="offre_id" value="{{ offre.Id_Offre ?? '' }}">

            {# Nom de l'offre, affiché en lecture seule pour rappel #}
            <div class="form-group">
                <label for="offre_nom">Offre</label>
                <input type="text" id="offre_nom" value="{{ offre.Nom_Offre ?? '' }}" readonly>
            </div>

            {# Nom de l'entreprise associée à l'offre #}
            <div class="form-group">
                <label for="entreprise_nom">Entreprise</label>
                <input type="text" id="entreprise_nom" value="{{ offre.Nom_Entreprise ?? '' }}" readonly>
            </div>

            {# Champ d'envoi du CV, obligatoire, limité aux fichiers PDF côté client #}
            <div class="form-group">
                <label for="cvUpload">
                    CV <span class="form-label-hint">(PDF uniquement)</span>
                </label>

                <div class="file-upload-group">
                    <input type="text"
                           readonly
                           placeholder="Aucun fichier sélectionné"
                           id="cvFileName"
                           aria-describedby="cvHelp">

                    <label for="cvUpload" class="file-upload-btn" aria-label="Téléverser un CV">
                        <i class="fa-solid fa-upload" aria-hidden="true"></i>
                    </label>

                    <input type="file"
                           id="cvUpload"
                           name="cv"
                           accept=".pdf,application/pdf"
                           required>
                </div>

                <small id="cvHelp">Le CV doit être fourni au format PDF.</small>
            </div>

            {# Champ d'envoi de la lettre de motivation, facultatif #}
            <div class="form-group">
                <label for="lmUpload">
                    Lettre de motivation
                    <span class="form-label-hint">(PDF uniquement, facultative)</span>
                </label>

                <div class="file-upload-group">
                    <input type="text"
                           readonly
                           placeholder="Aucun fichier sélectionné"
                           id="lmFileName"
                           aria-describedby="lmHelp">

                    <label for="lmUpload" class="file-upload-btn" aria-label="Téléverser une lettre de motivation">
                        <i class="fa-solid fa-upload" aria-hidden="true"></i>
                    </label>

                    <input type="file"
                           id="lmUpload"
                           name="lettre_motivation"
                           accept=".pdf,application/pdf">
                </div>

                <small id="lmHelp">La lettre de motivation est optionnelle et doit être en PDF.</small>
            </div>

            {# Boutons d'action : retour ou envoi de la candidature #}
            <div class="form-btn-row">
                <a href="/detail_offre?id={{ offre.Id_Offre }}" class="btn-secondary">Annuler</a>
                <button type="submit" class="btn-primary">Envoyer ma candidature</button>
            </div>

        </form>
    </div>
{% endblock %}