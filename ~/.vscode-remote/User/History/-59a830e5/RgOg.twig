{% extends "base.twig" %}

{# Titre affiché dans l'onglet du navigateur #}
{% block title %}
    Noter une entreprise - Kezan
{% endblock %}

{# Titre principal affiché dans la page #}
{% block page_title %}
    Noter une entreprise
{% endblock %}

{% block content %}
    <div class="add-content">
        <form class="add-form" method="post" action="/noter_entreprise">

            {# Identifiant de l'entreprise transmis discrètement au serveur #}
            <input type="hidden" name="entreprise_id" value="{{ entreprise.Id_Entreprise ?? '' }}">

            {# Nom de l'entreprise affiché en lecture seule pour rappel #}
            <div class="form-group">
                <label for="entreprise_nom">Entreprise</label>
                <input type="text"
                       id="entreprise_nom"
                       value="{{ entreprise.Nom_Entreprise ?? '' }}"
                       readonly>
            </div>

            {# Système de notation par étoiles, basé sur des boutons radio #}
            <div class="form-group">
                <fieldset class="star-rating-fieldset">
                    <legend>Note</legend>

                    <div class="star-rating">
                        <input type="radio" name="note" id="star5" value="5" required>
                        <label for="star5" aria-label="5 étoiles">
                            <i class="fa-solid fa-star" aria-hidden="true"></i>
                        </label>

                        <input type="radio" name="note" id="star4" value="4">
                        <label for="star4" aria-label="4 étoiles">
                            <i class="fa-solid fa-star" aria-hidden="true"></i>
                        </label>

                        <input type="radio" name="note" id="star3" value="3">
                        <label for="star3" aria-label="3 étoiles">
                            <i class="fa-solid fa-star" aria-hidden="true"></i>
                        </label>

                        <input type="radio" name="note" id="star2" value="2">
                        <label for="star2" aria-label="2 étoiles">
                            <i class="fa-solid fa-star" aria-hidden="true"></i>
                        </label>

                        <input type="radio" name="note" id="star1" value="1">
                        <label for="star1" aria-label="1 étoile">
                            <i class="fa-solid fa-star" aria-hidden="true"></i>
                        </label>
                    </div>
                </fieldset>
            </div>

            {# Champ libre pour ajouter un commentaire sur l'entreprise #}
            <div class="form-group">
                <label for="commentaire">Commentaire</label>
                <textarea id="commentaire"
                          name="commentaire"
                          rows="5"
                          placeholder="Votre avis sur cette entreprise..."></textarea>
            </div>

            {# Bouton d'envoi du formulaire de notation #}
            <button type="submit" class="btn-primary add-submit">
                Envoyer
            </button>

        </form>
    </div>
{% endblock %}