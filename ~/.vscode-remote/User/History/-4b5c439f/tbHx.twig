{% extends "base.twig" %}

{# Titre de l'onglet navigateur #}
{% block title %}Détail offre - Kezan{% endblock %}

{# Titre principal affiché dans la page #}
{% block page_title %}Détail offre{% endblock %}

{% block content %}
    <div class="detail-content">
        <div class="detail-card">

            {# En-tête principal de la fiche offre #}
            <div class="detail-card-header">
                <div class="company-logo large">
                    <i class="fa-solid fa-briefcase" style="font-size: 2rem; color: #999;" aria-hidden="true"></i>
                </div>

                <div class="detail-title">
                    <h2>{{ offre.Nom_Offre }}</h2>
                    <p><span class="badge">{{ offre.Domaine_Offre }}</span></p>
                </div>
            </div>

            {# Description détaillée de l'offre #}
            <div class="detail-section">
                <h3>Description</h3>
                <p class="detail-text">{{ offre.Description_Offre }}</p>
            </div>

            {# Profil attendu pour le poste ou le stage #}
            <div class="detail-section">
                <h3>Profil recherché</h3>
                <p class="detail-text">{{ offre.Profil_Recherche }}</p>
            </div>

            {# Informations complémentaires sur l'offre #}
            <div class="detail-section">
                <h3>Informations</h3>

                <div class="info-list">

                    {# Montant ou type de rémunération #}
                    <div class="info-row">
                        <div class="info-icon">
                            <i class="fa-solid fa-euro-sign" aria-hidden="true"></i>
                        </div>
                        <div>
                            <p class="info-label">Rémunération</p>
                            <p class="info-value">{{ offre.Remuneration }}</p>
                        </div>
                    </div>

                    {# Date de publication ou de disponibilité de l'offre #}
                    <div class="info-row">
                        <div class="info-icon">
                            <i class="fa-solid fa-calendar" aria-hidden="true"></i>
                        </div>
                        <div>
                            <p class="info-label">Date de l'offre</p>
                            <p class="info-value">{{ offre.Date_Offre }}</p>
                        </div>
                    </div>

                    {# Données chiffrées et entreprise associée #}
                    <div class="info-row-grid">
                        <div class="info-row">
                            <div class="info-icon">
                                <i class="fa-solid fa-user-graduate" aria-hidden="true"></i>
                            </div>
                            <div>
                                <p class="info-label">Étudiants recherchés</p>
                                <p class="info-value-bold">{{ offre.Nombre_Etudiants }}</p>
                            </div>
                        </div>

                        <div class="info-row">
                            <div class="info-icon">
                                <i class="fa-solid fa-building" aria-hidden="true"></i>
                            </div>
                            <div>
                                <p class="info-label">Entreprise</p>
                                <p class="info-value-bold">{{ offre.Nom_Entreprise }}</p>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            {# Zone des actions disponibles selon le rôle utilisateur #}
            <div class="detail-actions">

                {# Actions réservées aux étudiants #}
                {% if auth_role == 2 %}
                    <a href="/postuler?id={{ offre.Id_Offre }}" class="detail-action-btn">
                        <i class="fa-solid fa-paper-plane" aria-hidden="true"></i>
                        Postuler
                    </a>

                    {# Le bouton change selon la présence de l'offre dans la wishlist #}
                    {% if en_wishlist %}
                        <a href="/wishlist_retirer?id={{ offre.Id_Offre }}" class="detail-action-btn delete">
                            <i class="fa-solid fa-heart-crack" aria-hidden="true"></i>
                            Retirer de la wishlist
                        </a>
                    {% else %}
                        <a href="/wishlist_ajouter?id={{ offre.Id_Offre }}" class="detail-action-btn">
                            <i class="fa-regular fa-heart" aria-hidden="true"></i>
                            Ajouter à la wishlist
                        </a>
                    {% endif %}
                {% endif %}

                {# Actions réservées aux admins et pilotes #}
                {% if auth_role == 1 or auth_role == 3 %}
                    <a href="/modifier_offre?id={{ offre.Id_Offre }}" class="detail-action-btn edit">
                        <i class="fa-solid fa-pen" aria-hidden="true"></i>
                        Modifier
                    </a>

                    <a href="/supprimer_offre?id={{ offre.Id_Offre }}"
                       class="detail-action-btn delete"
                       onclick="return confirm('Supprimer cette offre ?')">
                        <i class="fa-solid fa-trash" aria-hidden="true"></i>
                        Supprimer
                    </a>
                {% endif %}
            </div>

        </div>
    </div>
{% endblock %}