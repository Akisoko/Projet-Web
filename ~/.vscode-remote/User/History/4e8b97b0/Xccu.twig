{% extends "base.twig" %}

{# Titre affiché dans l'onglet du navigateur #}
{% block title %}Statistiques - Kezan{% endblock %}

{# Titre principal affiché dans la page #}
{% block page_title %}Statistiques{% endblock %}

{% block content %}
    <div class="stats-content">

        {# Vue d'ensemble des indicateurs principaux #}
        <div class="stats-overview">

            <div class="stat-card">
                <div class="stat-icon">
                    <i class="fa-solid fa-briefcase" aria-hidden="true"></i>
                </div>
                <div class="stat-info">
                    <h3>{{ stats.total_offres }}</h3>
                    <p>Offres disponibles</p>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon">
                    <i class="fa-solid fa-building" aria-hidden="true"></i>
                </div>
                <div class="stat-info">
                    <h3>{{ stats.total_entreprises }}</h3>
                    <p>Entreprises</p>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon">
                    <i class="fa-solid fa-users" aria-hidden="true"></i>
                </div>
                <div class="stat-info">
                    <h3>{{ stats.total_utilisateurs }}</h3>
                    <p>Utilisateurs</p>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon">
                    <i class="fa-solid fa-file-alt" aria-hidden="true"></i>
                </div>
                <div class="stat-info">
                    <h3>{{ stats.total_candidatures }}</h3>
                    <p>Candidatures</p>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon">
                    <i class="fa-solid fa-chart-line" aria-hidden="true"></i>
                </div>
                <div class="stat-info">
                    <h3>{{ stats.moyenne_candidatures }}</h3>
                    <p>Candidatures / offre en moyenne</p>
                </div>
            </div>
        </div>

        {# Zone des statistiques détaillées sous forme de graphiques textuels #}
        <div class="charts-grid">

            {# Répartition des offres par domaine #}
            <div class="detail-card chart-stat-card">
                <h3>Offres par domaine</h3>

                {% for row in stats.offres_par_domaine %}
                    {% set pourcentage = stats.total_offres > 0 ? (row.nombre / stats.total_offres * 100)|round : 0 %}

                    <div class="progress-row">
                        <div class="progress-label-row">
                            <span>{{ row.Domaine_Offre }}</span>
                            <span>{{ row.nombre }}</span>
                        </div>

                        <div class="progress-track"
                             role="progressbar"
                             aria-label="Part des offres pour le domaine {{ row.Domaine_Offre }}"
                             aria-valuemin="0"
                             aria-valuemax="100"
                             aria-valuenow="{{ pourcentage }}">
                            <div class="progress-fill" style="width: {{ pourcentage }}%;"></div>
                        </div>
                    </div>
                {% else %}
                    <p class="empty-state-muted">Aucune donnée.</p>
                {% endfor %}
            </div>

            {# Répartition des offres par entreprise #}
            <div class="detail-card chart-stat-card">
                <h3>Offres par entreprise</h3>

                {% for row in stats.offres_par_entreprise %}
                    {% set pourcentage = stats.total_offres > 0 ? (row.nombre / stats.total_offres * 100)|round : 0 %}

                    <div class="progress-row">
                        <div class="progress-label-row">
                            <span>{{ row.Nom_Entreprise }}</span>
                            <span>{{ row.nombre }}</span>
                        </div>

                        <div class="progress-track"
                             role="progressbar"
                             aria-label="Part des offres pour l'entreprise {{ row.Nom_Entreprise }}"
                             aria-valuemin="0"
                             aria-valuemax="100"
                             aria-valuenow="{{ pourcentage }}">
                            <div class="progress-fill" style="width: {{ pourcentage }}%;"></div>
                        </div>
                    </div>
                {% else %}
                    <p class="empty-state-muted">Aucune donnée.</p>
                {% endfor %}
            </div>

            {# Classement des offres les plus ajoutées en wishlist #}
            <div class="detail-card chart-stat-card">
                <h3>Top 5 offres les plus wishlistées</h3>

                {% for row in stats.top_wishlist %}
                    <div class="wishlist-stat-item">
                        <div class="wishlist-stat-item-info">
                            <p>{{ row.Nom_Offre }}</p>
                            <p>{{ row.Nom_Entreprise }}</p>
                        </div>

                        <span class="badge-dark">
                            <i class="fa-solid fa-heart" aria-hidden="true"></i>
                            {{ row.nombre }}
                        </span>
                    </div>
                {% else %}
                    <p class="empty-state-muted">Aucune donnée.</p>
                {% endfor %}
            </div>

        </div>
    </div>
{% endblock %}