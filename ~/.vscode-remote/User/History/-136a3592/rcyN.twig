{% extends "base.twig" %}

{# Titre affiché dans l'onglet du navigateur #}
{% block title %}Recherche - Kezan{% endblock %}

{# Titre principal affiché dans la page #}
{% block page_title %}Recherche{% endblock %}

{% block content %}
    <div class="search-content">

        {# Formulaire principal de recherche avec mot-clé et filtre par type #}
        <form class="search-form" method="get" action="/recherche">
            <div class="search-bar">
                <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>

                {# Champ texte pour saisir la recherche #}
                <label for="searchQuery" class="sr-only">Rechercher</label>
                <input
                    type="search"
                    id="searchQuery"
                    name="q"
                    placeholder="Rechercher..."
                    value="{{ query ?? '' }}"
                >

                <button type="submit" class="btn-primary">Rechercher</button>
            </div>

            <div class="search-filters">
                {# Filtre permettant de limiter la recherche à un type d'entité #}
                <label for="searchType" class="sr-only">Type de résultat</label>
                <select id="searchType" name="type">
                    <option value="">Tout</option>
                    <option value="offre" {{ query_type == 'offre' ? 'selected' : '' }}>Offres</option>
                    <option value="entreprise" {{ query_type == 'entreprise' ? 'selected' : '' }}>Entreprises</option>

                    {% if auth_role == 1 or auth_role == 3 %}
                        <option value="profil" {{ query_type == 'profil' ? 'selected' : '' }}>Profils</option>
                    {% endif %}
                </select>
            </div>
        </form>

        {# Zone d'affichage des résultats #}
        <div class="search-results">

            {# Affiche les résultats si la variable existe et contient des éléments #}
            {% if resultats is defined and resultats is not empty %}
                {% for resultat in resultats %}
                    <a href="{{ resultat.url }}" class="entity-item">
                        <div class="result-icon">

                            {# Icône différente selon le type de résultat #}
                            {% if resultat.type == 'offre' %}
                                <i class="fa-solid fa-briefcase" aria-hidden="true"></i>
                            {% elseif resultat.type == 'entreprise' %}
                                <i class="fa-solid fa-building" aria-hidden="true"></i>
                            {% else %}
                                <i class="fa-solid fa-user" aria-hidden="true"></i>
                            {% endif %}
                        </div>

                        <div class="entity-item-info">
                            <h3>{{ resultat.titre }}</h3>
                            <p class="result-description">{{ resultat.description }}</p>
                        </div>

                        <span class="result-type-badge">{{ resultat.type }}</span>
                    </a>
                {% endfor %}

            {# Si une recherche a été faite mais qu'aucun résultat n'a été trouvé #}
            {% elseif query is defined and query is not empty %}
                <p class="empty-state">Aucun résultat pour "{{ query }}".</p>
            {% endif %}
        </div>

    </div>
{% endblock %}