{% extends "base.twig" %}

{# Titre affiché dans l'onglet du navigateur #}
{% block title %}
    Ajouter une entreprise - Kezan
{% endblock %}

{# Titre principal affiché dans la page #}
{% block page_title %}
    Ajouter une entreprise
{% endblock %}

{% block content %}
    <div class="add-content">

        {# Affiche le message d'erreur si validation échouée #}
        {% if erreur %}
            <p class="error-message" style="color:red;">{{ erreur }}</p>
        {% endif %}

        {# Formulaire d'ajout d'entreprise #}
        <form class="add-form" method="post" action="/ajouter_entreprise">

            {# Nom de l'entreprise #}
            <div class="form-group">
                <label for="nom">Nom entreprise</label>
                <input type="text" id="nom" name="nom" required>
            </div>

            {# Site web de l'entreprise #}
            <div class="form-group">
                <label for="site_web">Site web</label>
                <input type="url" id="site_web" name="site_web" required>
            </div>

            {# Date de création de l'entreprise #}
            <div class="form-group">
                <label for="date_creation">Date de création</label>
                <input type="date" id="date_creation" name="date_creation" required>
            </div>

            {# Domaine d'activité #}
            <div class="form-group">
                <label for="domaine">Domaine</label>
                <input type="text" id="domaine" name="domaine" required>
            </div>

            {# Effectifs de l'entreprise #}
            <div class="form-group">
                <label for="nb_employes">Nombre d'employés</label>
                <input type="number" id="nb_employes" name="nb_employes" min="0" required>
            </div>

            {# Capacité d'accueil stagiaires #}
            <div class="form-group">
                <label for="nb_stagiaires">Nombre de stagiaires</label>
                <input type="number" id="nb_stagiaires" name="nb_stagiaires" min="0" required>
            </div>

            {# Contact email #}
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" required>
            </div>

            {# Contact téléphone #}
            <div class="form-group">
                <label for="telephone">Téléphone</label>
                <input type="tel" id="telephone" name="telephone" required>
            </div>

            {# Description détaillée #}
            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" rows="5" required></textarea>
            </div>

            {# Bouton de soumission du formulaire #}
            <button type="submit" class="btn-primary add-submit">
                <i class="fa-solid fa-plus"></i> Ajouter l'entreprise
            </button>

        </form>
    </div>
{% endblock %}