{% extends "base.twig" %}

{# Titre de l'onglet navigateur #}
{% block title %}Accueil - Kezan{% endblock %}

{# Titre affiché dans la page principale #}
{% block page_title %}Accueil{% endblock %}

{% block content %}
    <div class="home-content">

        {# ============================= #}
        {# Vue réservée aux admins/pilotes #}
        {# ============================= #}
        {% if auth_role == 1 or auth_role == 3 %}

            {# Bloc des statistiques globales de la plateforme #}
            <div class="stats-overview section-block">
                <div class="stat-card">
                    <div class="stat-icon"><i class="fa-solid fa-briefcase"></i></div>
                    <div class="stat-info">
                        <h3>{{ stats.total_offres }}</h3>
                        <p>Offres disponibles</p>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon"><i class="fa-solid fa-building"></i></div>
                    <div class="stat-info">
                        <h3>{{ stats.total_entreprises }}</h3>
                        <p>Entreprises</p>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon"><i class="fa-solid fa-file-alt"></i></div>
                    <div class="stat-info">
                        <h3>{{ stats.total_candidatures }}</h3>
                        <p>Candidatures</p>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon"><i class="fa-solid fa-chart-line"></i></div>
                    <div class="stat-info">
                        <h3>{{ stats.moyenne_candidatures }}</h3>
                        <p>Candidatures / offre</p>
                    </div>
                </div>
            </div>

            {# Affiche le top des offres wishlistées seulement si des données existent #}
            {% if stats.top_wishlist is not empty %}
                <section class="section-block">
                    <h2 class="section-header">Top offres wishlistées</h2>

                    <div class="cards-grid">
                        {# Parcourt chaque offre populaire enregistrée dans les statistiques #}
                        {% for row in stats.top_wishlist %}
                            <div class="company-card top-wishlist-card">
                                <div>
                                    <p class="card-title">{{ row.Nom_Offre }}</p>
                                    <p class="card-subtitle">{{ row.Nom_Entreprise }}</p>
                                </div>

                                <span class="badge-dark">
                                    <i class="fa-solid fa-heart"></i>{{ row.nombre }}
                                </span>
                            </div>
                        {% endfor %}
                    </div>
                </section>
            {% endif %}

        {% endif %}

        {# ===================================== #}
        {# Wishlist visible uniquement étudiant #}
        {# ===================================== #}
        {% if auth_role == 2 and wishlist is defined and wishlist is not empty %}
            <section class="section-block">
                <h2 class="section-header">Ma wishlist</h2>

                <div class="cards-grid">
                    {# Liste les offres enregistrées en favoris par l'étudiant connecté #}
                    {% for offre in wishlist %}
                        <a href="/detail_offre?id={{ offre.Id_Offre }}" class="company-card">
                            <div class="card-header-row">
                                <div class="card-icon">
                                    <i class="fa-solid fa-briefcase"></i>
                                </div>

                                <div>
                                    <p class="card-title">{{ offre.Nom_Offre }}</p>
                                    <p class="card-subtitle">{{ offre.Nom_Entreprise }}</p>
                                </div>
                            </div>

                            <div class="card-footer-row">
                                <span><i class="fa-solid fa-euro-sign"></i>{{ offre.Remuneration }}</span>
                                <span><i class="fa-solid fa-heart heart-red"></i>En wishlist</span>
                            </div>
                        </a>
                    {% endfor %}
                </div>
            </section>
        {% endif %}

        {# ===================================== #}
        {# Dernières offres visibles pour tous #}
        {# ===================================== #}
        <section class="section-block">
            <h2 class="section-header">
                {# Le titre change légèrement selon le rôle connecté #}
                {% if auth_role == 2 %}Dernières offres{% else %}Offres récentes{% endif %}
            </h2>

            <div class="cards-grid">
                {# Parcourt les dernières offres envoyées par le contrôleur #}
                {% for offre in dernieres_offres %}
                    <a href="/detail_offre?id={{ offre.Id_Offre }}" class="company-card">
                        <div class="card-header-row">
                            <div class="card-icon">
                                <i class="fa-solid fa-briefcase"></i>
                            </div>

                            <div>
                                <p class="card-title">{{ offre.Nom_Offre }}</p>
                                <p class="card-subtitle">{{ offre.Nom_Entreprise }}</p>
                                <span class="badge">{{ offre.Domaine_Offre }}</span>
                            </div>
                        </div>

                        <p class="card-description">{{ offre.Description_Offre }}</p>

                        <div class="card-footer-row">
                            <span><i class="fa-solid fa-euro-sign"></i>{{ offre.Remuneration }}</span>
                            <span><i class="fa-solid fa-calendar"></i>{{ offre.Date_Offre }}</span>
                        </div>
                    </a>
                {% else %}
                    {# Message affiché si aucune offre n'est disponible #}
                    <p class="empty-state">Aucune offre disponible.</p>
                {% endfor %}
            </div>
        </section>

    </div>
{% endblock %}