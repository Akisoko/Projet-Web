{% extends "base.twig" %}

{# Titre de l'onglet navigateur #}
{% block title %}Modifier une entreprise - Kezan{% endblock %}

{# Titre principal affiché dans la page #}
{% block page_title %}Modifier une entreprise{% endblock %}

{% block content %}
    <div class="add-content">

        {# Message d'erreur affiché si le contrôleur renvoie un problème #}
        {% if erreur %}
            <p class="form-error">{{ erreur }}</p>
        {% endif %}

        {# Formulaire de modification de l'entreprise #}
        <form class="add-form" method="post" action="/modifier_entreprise?id={{ entreprise.Id_Entreprise }}">

            {# Nom de l'entreprise #}
            <div class="form-group">
                <label for="nom">Nom entreprise</label>
                <input type="text" id="nom" name="nom" value="{{ entreprise.Nom_Entreprise }}" required>
            </div>

            {# Site web de l'entreprise #}
            <div class="form-group">
                <label for="site_web">Site web</label>
                <input type="url" id="site_web" name="site_web" value="{{ entreprise.Site_Web }}" required>
            </div>

            {# Date de création de l'entreprise #}
            <div class="form-group">
                <label for="date_creation">Date de création</label>
                <input type="date" id="date_creation" name="date_creation" value="{{ entreprise.Date_Creation }}" required>
            </div>

            {# Domaine d'activité de l'entreprise #}
            <div class="form-group">
                <label for="domaine">Domaine</label>
                <input type="text" id="domaine" name="domaine" value="{{ entreprise.Domaine_Entreprise }}" required>
            </div>

            {# Nombre total d'employés #}
            <div class="form-group">
                <label for="nb_employes">Nombre d'employés</label>
                <input type="number" id="nb_employes" name="nb_employes" value="{{ entreprise.Nombre_Employes }}" required>
            </div>

            {# Nombre de stagiaires accueillis #}
            <div class="form-group">
                <label for="nb_stagiaires">Nombre de stagiaires</label>
                <input type="number" id="nb_stagiaires" name="nb_stagiaires" value="{{ entreprise.Nombre_Stagiaires }}" required>
            </div>

            {# Adresse email de contact #}
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" value="{{ entreprise.Mail }}" required>
            </div>

            {# Numéro de téléphone de l'entreprise #}
            <div class="form-group">
                <label for="telephone">Téléphone</label>
                <input type="text" id="telephone" name="telephone" value="{{ entreprise.Telephone }}" required>
            </div>

            {# Description détaillée de l'entreprise #}
            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" rows="5" required>{{ entreprise.Description_Entreprise }}</textarea>
            </div>

            {# Boutons d'action du formulaire : annuler ou enregistrer #}
            <div class="form-btn-row">
                <a href="/detail_entreprise?id={{ entreprise.Id_Entreprise }}" class="btn-secondary">
                    Annuler
                </a>

                <button type="submit" class="btn-primary">
                    Enregistrer les modifications
                </button>
            </div>

        </form>
    </div>
{% endblock %}