{% extends "base.twig" %}

{# Titre affiché dans l'onglet du navigateur #}
{% block title %}Profil utilisateur - Kezan{% endblock %}

{# Titre principal affiché dans la page #}
{% block page_title %}Profil utilisateur{% endblock %}

{% block content %}
    <div class="detail-content">
        <div class="detail-card">

            {# En-tête principal de la fiche utilisateur #}
            <div class="detail-card-header">
                <div class="company-logo large circle">
                    <i class="fa-solid fa-user" style="font-size: 2rem; color: #999;" aria-hidden="true"></i>
                </div>

                <div class="detail-title">
                    <h2>{{ utilisateur.Prenom }} {{ utilisateur.Nom_Utilisateur }}</h2>
                    <p>
                        <span class="badge">
                            {# Affiche le libellé du rôle selon l'identifiant du rôle utilisateur #}
                            {% if utilisateur.Id_Role == 1 %}
                                Admin
                            {% elseif utilisateur.Id_Role == 2 %}
                                Étudiant
                            {% elseif utilisateur.Id_Role == 3 %}
                                Pilote
                            {% endif %}
                        </span>
                    </p>
                </div>
            </div>

            {# Bloc des informations personnelles de l'utilisateur #}
            <div class="detail-section">
                <h3>Informations personnelles</h3>

                <div class="info-list">

                    {# Numéro de téléphone, ou valeur de secours si non renseigné #}
                    <div class="info-row">
                        <div class="info-icon">
                            <i class="fa-solid fa-phone" aria-hidden="true"></i>
                        </div>
                        <div>
                            <p class="info-label">Téléphone</p>
                            <p class="info-value">{{ utilisateur.Telephone|default('Non renseigné') }}</p>
                        </div>
                    </div>

                    {# Adresse email de l'utilisateur #}
                    <div class="info-row">
                        <div class="info-icon">
                            <i class="fa-solid fa-envelope" aria-hidden="true"></i>
                        </div>
                        <div>
                            <p class="info-label">Email</p>
                            <p class="info-value">{{ utilisateur.Email }}</p>
                        </div>
                    </div>

                    {# Informations complémentaires regroupées sur deux colonnes #}
                    <div class="info-row-grid">
                        <div class="info-row">
                            <div class="info-icon">
                                <i class="fa-solid fa-venus-mars" aria-hidden="true"></i>
                            </div>
                            <div>
                                <p class="info-label">Genre</p>
                                <p class="info-value">{{ utilisateur.Genre }}</p>
                            </div>
                        </div>

                        <div class="info-row">
                            <div class="info-icon">
                                <i class="fa-solid fa-cake-candles" aria-hidden="true"></i>
                            </div>
                            <div>
                                <p class="info-label">Date de naissance</p>
                                <p class="info-value">{{ utilisateur.Date_de_Naissance }}</p>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            {# Actions disponibles selon le rôle de l'utilisateur connecté #}
            <div class="detail-actions">
                {% if auth_role == 1 or (auth_role == 3 and utilisateur.Id_Role == 2) %}
                    <a href="/modifier_utilisateur?id={{ utilisateur.Id_Utilisateur }}" class="detail-action-btn edit">
                        <i class="fa-solid fa-pen" aria-hidden="true"></i>
                        Modifier
                    </a>

                    <a href="/supprimer_utilisateur?id={{ utilisateur.Id_Utilisateur }}"
                       class="detail-action-btn delete"
                       onclick="return confirm('Supprimer cet utilisateur ?')">
                        <i class="fa-solid fa-trash" aria-hidden="true"></i>
                        Supprimer
                    </a>
                {% endif %}
            </div>

        </div>
    </div>
{% endblock %}