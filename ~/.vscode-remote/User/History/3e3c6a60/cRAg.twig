{% extends "base_connexion.twig" %}

{# Titre affiché dans l'onglet du navigateur #}
{% block title %}Connexion - Kezan{% endblock %}

{% block content %}
    <div class="auth-container">

        {# Côté gauche : Logo et nom de marque #}
        <div class="auth-logo-side">
            <div class="logo-container">
                {# Logo Horde WoW (thème Kezan = île gobeline de WoW) #}
                <img src="https://img.icons8.com/color/512/world-of-warcraft-horde.png" 
                     alt="Logo Kezan" 
                     class="landing-logo">
            </div>
            <h1 class="brand-name">Kezan</h1>
        </div>

        {# Côté droit : Formulaire de connexion #}
        <div class="auth-form-side">
            <div class="auth-form-card">
                <h2>Connexion</h2>
                <p class="auth-subtitle">Connectez-vous pour commencer</p>

                {# Affiche le message d'erreur si authentification échouée #}
                {% if erreur %}
                    <div class="error-message" style="color: red; margin-bottom: 1rem;">
                        {{ erreur }}
                    </div>
                {% endif %}

                {# Formulaire de connexion #}
                <form class="auth-form" method="POST" action="/connexion">
                    <div class="form-group">
                        <label for="email">E-mail</label>
                        <input type="email" 
                               id="email" 
                               name="email" 
                               required 
                               aria-describedby="email-help">
                        <small id="email-help" class="form-help">Votre adresse e-mail</small>
                    </div>

                    <div class="form-group">
                        <label for="mot_de_passe">Mot de passe</label>
                        <input type="password" 
                               id="mot_de_passe" 
                               name="mot_de_passe" 
                               required 
                               aria-describedby="password-help">
                        <small id="password-help" class="form-help">Mot de passe de votre compte</small>
                    </div>

                    {# Bouton de soumission #}
                    <button type="submit" class="btn-primary auth-submit">
                        <i class="fa-solid fa-sign-in-alt" aria-hidden="true"></i>
                        Se connecter
                    </button>
                </form>

                {# Lien vers l'inscription #}
                <p class="auth-footer">
                    Pas encore de compte ? 
                    <a href="/inscription">Créer un compte</a>
                </p>
            </div>
        </div>
    </div>
{% endblock %}