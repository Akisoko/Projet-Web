{% extends "base.twig" %}

{# Titre affiché dans l'onglet du navigateur #}
{% block title %}Profil - Kezan{% endblock %}

{# Titre principal affiché dans la page #}
{% block page_title %}Mon profil{% endblock %}

{% block content %}
    <div class="detail-content">
        <div class="detail-card">

            {# En-tête de la fiche profil avec identité et bouton de modification #}
            <div class="detail-card-header">
                <div class="company-logo large circle">
                    <i class="fa-solid fa-user" style="font-size: 2rem; color: #999;" aria-hidden="true"></i>
                </div>

                <div class="detail-title">
                    <h2>{{ utilisateur.Prenom }} {{ utilisateur.Nom_Utilisateur }}</h2>
                    <p>{{ utilisateur.Email }}</p>
                </div>

                <a href="/modifier_profil" class="btn-primary ml-auto">
                    <i class="fa-solid fa-pen" aria-hidden="true"></i>
                    Modifier
                </a>
            </div>

            {# Bloc d'informations personnelles de l'utilisateur #}
            <div class="detail-section">
                <h3>Informations personnelles</h3>

                <div class="info-list">

                    {# Téléphone, avec valeur de secours si non renseigné #}
                    <div class="info-row">
                        <div class="info-icon">
                            <i class="fa-solid fa-phone" aria-hidden="true"></i>
                        </div>
                        <div>
                            <p class="info-label">Téléphone</p>
                            <p class="info-value">{{ utilisateur.Telephone|default('Non renseigné') }}</p>
                        </div>
                    </div>

                    {# Adresse email #}
                    <div class="info-row">
                        <div class="info-icon">
                            <i class="fa-solid fa-envelope" aria-hidden="true"></i>
                        </div>
                        <div>
                            <p class="info-label">Email</p>
                            <p class="info-value">{{ utilisateur.Email }}</p>
                        </div>
                    </div>

                    {# Genre et date de naissance regroupés sur une ligne double #}
                    <div class="info-row-grid">
                        <div class="info-row">
                            <div class="info-icon">
                                <i class="fa-solid fa-venus-mars" aria-hidden="true"></i>
                            </div>
                            <div>
                                <p class="info-label">Genre</p>
                                <p class="info-value">{{ utilisateur.Genre }}</p>
                            </div>
                        </div>

                        <div class="info-row">
                            <div class="info-icon">
                                <i class="fa-solid fa-cake-candles" aria-hidden="true"></i>
                            </div>
                            <div>
                                <p class="info-label">Date de naissance</p>
                                <p class="info-value">{{ utilisateur.Date_de_Naissance }}</p>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            {# Bloc des candidatures visible pour les étudiants et les pilotes #}
            {% if utilisateur.Id_Role == 2 or utilisateur.Id_Role == 3 %}
                <div class="detail-section">
                    <h3>
                        {% if utilisateur.Id_Role == 2 %}
                            Mes candidatures
                        {% else %}
                            Candidatures des étudiants
                        {% endif %}
                    </h3>

                    {# Liste des candidatures associées au profil #}
                    {% for candidature in candidatures %}
                        <a href="/detail_candidature?offre={{ candidature.Id_Offre }}&utilisateur={{ candidature.Id_Utilisateur }}"
                           class="candidature-item">
                            <div>
                                <p class="info-value-bold">{{ candidature.Nom_Offre }}</p>
                                <p class="info-label" style="margin-top: 2px;">{{ candidature.Nom_Entreprise }}</p>

                                {# Pour un pilote, affiche aussi le nom de l'étudiant si disponible #}
                                {% if utilisateur.Id_Role == 3 and candidature.Nom_Utilisateur is defined %}
                                    <p class="info-label" style="margin-top: 2px;">
                                        <i class="fa-solid fa-user" aria-hidden="true"></i>
                                        {{ candidature.Prenom }} {{ candidature.Nom_Utilisateur }}
                                    </p>
                                {% endif %}
                            </div>

                            <span class="badge">{{ candidature.Date_Candid|default('') }}</span>
                        </a>
                    {% else %}
                        {# Message affiché si aucune candidature n'est trouvée #}
                        <p style="color: #999;">Aucune candidature trouvée.</p>
                    {% endfor %}
                </div>
            {% endif %}

        </div>
    </div>
{% endblock %}