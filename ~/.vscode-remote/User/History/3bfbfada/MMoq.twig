<!DOCTYPE html>
<html lang="fr">
<head>
    {# Encodage des caractères en UTF-8 #}
    <meta charset="UTF-8">

    {# Permet un affichage responsive sur mobile et tablette #}
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    {# Titre dynamique de la page, redéfini dans les templates enfants #}
    <title>{% block title %}Kezan{% endblock %}</title>

    {# Librairie d'icônes Font Awesome utilisée dans l'interface #}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    {# Feuille de style principale du projet #}
    <link rel="stylesheet" href="/assets/style.css">
</head>

<body class="landing-page">

    {# Bloc principal du contenu, remplacé par les vues enfants #}
    {% block content %}
    {% endblock %}

    {# Script JavaScript principal du projet #}
    <script src="/assets/script.js" defer></script>
</body>
</html>