{% extends "base.twig" %}

{# Titre affiché dans l'onglet du navigateur #}
{% block title %}Inscription - Kezan{% endblock %}

{% block content %}
    <div class="auth-container signup-page">
        <div class="auth-form-card signup-card">

            {# En-tête du bloc d'inscription avec logo et titre #}
            <div class="signup-header">
                <div class="logo-container small">
                    <img src="https://img.icons8.com/color/512/world-of-warcraft-horde.png"
                         alt="Logo Kezan"
                         class="landing-logo">
                </div>

                <div>
                    <h2>Créer un compte</h2>
                    <p class="auth-subtitle">Inscrivez-vous pour commencer</p>
                </div>
            </div>

            {# Message d'erreur affiché si le contrôleur en transmet un #}
            {% if erreur %}
                <p class="error-message" style="color: red; margin-bottom: 1rem;">{{ erreur }}</p>
            {% endif %}

            {# Formulaire principal d'inscription #}
            <form class="auth-form signup-form" method="POST" action="/inscription">

                {# Choix du rôle du compte créé, visible seulement pour admin/pilote #}
                {% if auth_role == 1 or auth_role == 3 %}
                    <div class="form-row">
                        <div class="form-group" style="width: 100%;">
                            <label for="role_cree">Rôle pour ce nouveau compte</label>
                            <select name="role_cree"
                                    id="role_cree"
                                    class="select-field"
                                    style="width: 100%; padding: 0.75rem; border: 1px solid #ddd; border-radius: 8px; font-size: 0.95rem; margin-bottom: 1rem;">
                                <option value="2">Étudiant</option>

                                {% if auth_role == 1 %}
                                    <option value="3">Pilote</option>
                                {% endif %}
                            </select>
                        </div>
                    </div>
                {% endif %}

                {# Ligne civilité + email #}
                <div class="form-row">
                    <div class="form-group">
                        <label>Civilité</label>

                        <div class="radio-group">
                            <label class="radio-label">
                                <input type="radio" name="civilite" value="mr" checked>
                                <span>Mr</span>
                            </label>

                            <label class="radio-label">
                                <input type="radio" name="civilite" value="mme">
                                <span>Mme</span>
                            </label>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="email">Email</label>
                        <input type="email" id="email" name="email" required>
                    </div>
                </div>

                {# Ligne nom + téléphone #}
                <div class="form-row">
                    <div class="form-group">
                        <label for="nom">Nom</label>
                        <input type="text" id="nom" name="nom" required>
                    </div>

                    <div class="form-group">
                        <label for="telephone">Téléphone</label>
                        <input type="tel" id="telephone" name="telephone" required>
                    </div>
                </div>

                {# Ligne prénom + mot de passe #}
                <div class="form-row">
                    <div class="form-group">
                        <label for="prenom">Prénom</label>
                        <input type="text" id="prenom" name="prenom" required>
                    </div>

                    <div class="form-group">
                        <label for="mot_de_passe">Mot de passe</label>
                        <input type="password" id="mot_de_passe" name="mot_de_passe" required>
                    </div>
                </div>

                {# Ligne date de naissance + confirmation mot de passe #}
                <div class="form-row">
                    <div class="form-group">
                        <label>Date de naissance</label>

                        <div class="date-group">
                            {# Sélecteur du jour #}
                            <select name="jour" aria-label="Jour de naissance" required>
                                <option value="">JJ</option>
                                {% for j in 1..31 %}
                                    <option value="{{ j < 10 ? '0' ~ j : j }}">
                                        {{ j < 10 ? '0' ~ j : j }}
                                    </option>
                                {% endfor %}
                            </select>

                            {# Sélecteur du mois #}
                            <select name="mois" aria-label="Mois de naissance" required>
                                <option value="">MM</option>
                                {% for m in 1..12 %}
                                    <option value="{{ m < 10 ? '0' ~ m : m }}">
                                        {{ m < 10 ? '0' ~ m : m }}
                                    </option>
                                {% endfor %}
                            </select>

                            {# Sélecteur de l'année #}
                            <select name="annee" aria-label="Année de naissance" required>
                                <option value="">AAAA</option>
                                {% for a in 1990..2010 %}
                                    <option value="{{ a }}">{{ a }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="mot_de_passe_confirmation">Confirmation mot de passe</label>
                        <input type="password"
                               id="mot_de_passe_confirmation"
                               name="mot_de_passe_confirmation"
                               required>
                    </div>
                </div>

                {# Bouton d'envoi du formulaire #}
                <button type="submit" class="btn-primary auth-submit">
                    S'inscrire
                </button>
            </form>

            {# Lien de bas de formulaire différent selon le contexte utilisateur #}
            <p class="auth-footer">
                {% if not auth_role %}
                    Déjà un compte ? <a href="/connexion">Se connecter</a>
                {% else %}
                    <a href="/accueil">Retour à l'accueil</a>
                {% endif %}
            </p>
        </div>
    </div>
{% endblock %}