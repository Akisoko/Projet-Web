{% extends "base.twig" %}

{# Titre affiché dans l'onglet du navigateur #}
{% block title %}Détail candidature - Kezan{% endblock %}

{# Titre principal affiché dans la page #}
{% block page_title %}Détail candidature{% endblock %}

{% block content %}
    <div class="detail-content">
        <div class="detail-card">

            {# En-tête principal de la fiche candidature #}
            <div class="detail-card-header">
                <div class="company-logo large">
                    <i class="fa-solid fa-file-lines" style="font-size: 2rem; color: #999;" aria-hidden="true"></i>
                </div>

                <div class="detail-title">
                    <h2>{{ candidature.Nom_Offre }}</h2>
                    <p><span class="badge">{{ candidature.Nom_Entreprise }}</span></p>
                </div>
            </div>

            {# Bloc visible uniquement pour les admins et pilotes : informations du candidat #}
            {% if auth_role == 1 or auth_role == 3 %}
                <div class="detail-section">
                    <h3>Candidat</h3>

                    <div class="info-list">
                        <div class="info-row">
                            <div class="info-icon">
                                <i class="fa-solid fa-user" aria-hidden="true"></i>
                            </div>
                            <div>
                                <p class="info-label">Nom complet</p>
                                <p class="info-value">{{ candidature.Prenom }} {{ candidature.Nom_Utilisateur }}</p>
                            </div>
                        </div>

                        <div class="info-row">
                            <div class="info-icon">
                                <i class="fa-solid fa-envelope" aria-hidden="true"></i>
                            </div>
                            <div>
                                <p class="info-label">Email</p>
                                <p class="info-value">{{ candidature.Email }}</p>
                            </div>
                        </div>
                    </div>
                </div>
            {% endif %}

            {# Informations générales sur la candidature #}
            <div class="detail-section">
                <h3>Informations de la candidature</h3>

                <div class="info-list">
                    <div class="info-row">
                        <div class="info-icon">
                            <i class="fa-solid fa-calendar" aria-hidden="true"></i>
                        </div>
                        <div>
                            <p class="info-label">Date de candidature</p>
                            <p class="info-value">{{ candidature.Date_Candid }}</p>
                        </div>
                    </div>

                    <div class="info-row">
                        <div class="info-icon">
                            <i class="fa-solid fa-building" aria-hidden="true"></i>
                        </div>
                        <div>
                            <p class="info-label">Entreprise</p>
                            <p class="info-value">
                                <a href="/detail_entreprise?id={{ candidature.Id_Entreprise }}" style="color: inherit;">
                                    {{ candidature.Nom_Entreprise }}
                                </a>
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            {# Section de téléchargement des documents transmis avec la candidature #}
            <div class="detail-section">
                <h3>Documents</h3>

                <div class="candidature-documents">

                    {# Téléchargement du CV si disponible #}
                    {% if candidature.CV %}
                        <a href="/{{ candidature.CV }}" class="document-download-btn" download>
                            <div class="document-icon">
                                <i class="fa-solid fa-file-pdf" aria-hidden="true"></i>
                            </div>

                            <div class="document-info">
                                <p class="document-name">Curriculum Vitae</p>
                                <p class="document-hint">Cliquer pour télécharger</p>
                            </div>

                            <i class="fa-solid fa-download document-arrow" aria-hidden="true"></i>
                        </a>
                    {% else %}
                        <div class="document-missing">
                            <i class="fa-solid fa-file-circle-xmark" aria-hidden="true"></i>
                            <span>Aucun CV fourni</span>
                        </div>
                    {% endif %}

                    {# Téléchargement de la lettre de motivation si disponible #}
                    {% if candidature.Lettre_Motivation %}
                        <a href="/{{ candidature.Lettre_Motivation }}" class="document-download-btn" download>
                            <div class="document-icon">
                                <i class="fa-solid fa-file-pdf" aria-hidden="true"></i>
                            </div>

                            <div class="document-info">
                                <p class="document-name">Lettre de motivation</p>
                                <p class="document-hint">Cliquer pour télécharger</p>
                            </div>

                            <i class="fa-solid fa-download document-arrow" aria-hidden="true"></i>
                        </a>
                    {% else %}
                        <div class="document-missing">
                            <i class="fa-solid fa-file-circle-xmark" aria-hidden="true"></i>
                            <span>Aucune lettre de motivation fournie</span>
                        </div>
                    {% endif %}

                </div>
            </div>

            {# Actions de navigation liées à la candidature #}
            <div class="detail-actions">
                <a href="/profil" class="detail-action-btn">
                    <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
                    Retour au profil
                </a>

                <a href="/detail_offre?id={{ candidature.Id_Offre }}" class="detail-action-btn edit">
                    <i class="fa-solid fa-briefcase" aria-hidden="true"></i>
                    Voir l'offre
                </a>
            </div>

        </div>
    </div>
{% endblock %}