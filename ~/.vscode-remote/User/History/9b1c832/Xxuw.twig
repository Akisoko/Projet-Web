{% extends "base_connexion.twig" %}

{# Titre affiché dans l'onglet du navigateur #}
{% block title %}
    Kezan - Bienvenue
{% endblock %}

{% block content %}

    {# Premier écran d'accueil affiché au chargement #}
    <div class="landing-screen" id="welcomeScreen">
        <div class="landing-card">
            <div class="logo-container">
                <img src="https://img.icons8.com/color/512/world-of-warcraft-horde.png"
                     alt="Logo Kezan"
                     class="landing-logo">
            </div>

            <h1 class="brand-name">Kezan</h1>

            {# Bouton qui doit déclencher l'affichage du second écran #}
            <button class="landing-btn" id="startBtn" type="button">
                Commencer
            </button>
        </div>
    </div>

    {# Second écran masqué au départ, destiné aux choix de connexion #}
    <div class="landing-screen hidden" id="loginScreen">
        <div class="landing-card">
            <div class="logo-container">
                <img src="https://img.icons8.com/color/512/world-of-warcraft-horde.png"
                     alt="Logo Kezan"
                     class="landing-logo">
            </div>

            <h2 class="login-title">Sign up/Log in</h2>

            <div class="login-form">
                {# Accès en mode invité #}
                <a href="/accueil" class="btn-outline">
                    Continuer en tant qu'invité
                </a>

                {# Redirection vers la page de connexion #}
                <a href="/connexion" class="btn-primary">
                    Se connecter
                </a>
            </div>
        </div>
    </div>

{% endblock %}