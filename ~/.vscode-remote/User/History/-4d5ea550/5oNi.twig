{% extends "base.twig" %}

{# Titre affiché dans l'onglet du navigateur #}
{% block title %}Wishlist - Kezan{% endblock %}

{# Titre principal affiché dans la page #}
{% block page_title %}Wishlist{% endblock %}

{% block content %}
    <div class="entity-content-wide">

        {# Grille des offres enregistrées dans la wishlist #}
        <div class="cards-grid">
            {% for offre in wishlist %}

                {# Carte de wishlist : conteneur non interactif pour éviter les éléments interactifs imbriqués #}
                <div class="company-card wishlist-card">

                    {# Lien principal vers le détail de l'offre #}
                    <a href="/detail_offre?id={{ offre.Id_Offre }}"
                       class="wishlist-card-link">
                        <div class="card-header-row">
                            <div class="card-icon">
                                <i class="fa-solid fa-briefcase" aria-hidden="true"></i>
                            </div>

                            <div>
                                <p class="card-title">{{ offre.Nom_Offre }}</p>
                                <p class="card-subtitle">{{ offre.Nom_Entreprise }}</p>
                                <span class="badge">{{ offre.Domaine_Offre }}</span>
                            </div>
                        </div>

                        <p class="card-description">{{ offre.Description_Offre }}</p>

                        <div class="card-footer-row">
                            <span>
                                <i class="fa-solid fa-euro-sign" aria-hidden="true"></i>
                                {{ offre.Remuneration }}
                            </span>

                            <span>
                                <i class="fa-solid fa-calendar" aria-hidden="true"></i>
                                {{ offre.Date_Offre }}
                            </span>
                        </div>
                    </a>

                    {# Bouton/lien secondaire pour retirer l'offre de la wishlist #}
                    <a href="/wishlist_retirer?id={{ offre.Id_Offre }}"
                       class="wishlist-remove-btn"
                       aria-label="Retirer {{ offre.Nom_Offre }} de la wishlist"
                       onclick="return confirm('Retirer cette offre de la wishlist ?')">
                        <i class="fa-solid fa-heart" aria-hidden="true"></i>
                    </a>

                </div>

            {% else %}
                {# Message affiché si la wishlist est vide #}
                <p class="empty-state">Votre wishlist est vide.</p>
            {% endfor %}
        </div>

    </div>
{% endblock %}